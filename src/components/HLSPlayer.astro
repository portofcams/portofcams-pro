---
interface Props {
  hlsUrl: string;
  cameraName: string;
  /** Still shown before play + whenever the feed drops, so the view is never a dead grey box. */
  poster?: string;
}

const { hlsUrl, cameraName, poster = '' } = Astro.props;
---

<div class="hls-player-wrap" data-hls-url={hlsUrl} aria-label={cameraName}>
  <video class="hls-video" playsinline muted autoplay poster={poster}></video>

  <div class="player-chrome">
    <div class="player-status" data-state="connecting">
      <span class="live-dot"></span>
      <span class="live-text mono">CONNECTING</span>
    </div>
    <div class="player-controls">
      <button class="player-btn mute-btn" title="Toggle sound" aria-label="Toggle sound">
        <svg class="icon-muted" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <line x1="23" y1="9" x2="17" y2="15"></line>
          <line x1="17" y1="9" x2="23" y2="15"></line>
        </svg>
        <svg class="icon-unmuted" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
        </svg>
      </button>
      <button class="player-btn fullscreen-btn" title="Fullscreen" aria-label="Toggle fullscreen">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Resilient status overlay — the poster (the view) stays visible behind it, never a dead grey box. -->
  <div class="player-overlay" hidden>
    <div class="overlay-pill">
      <span class="overlay-spinner"></span>
      <span class="mono overlay-text">Connecting to the live feed…</span>
    </div>
  </div>
</div>

<style>
  .hls-player-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .hls-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: var(--deep);
  }

  .player-chrome {
    position: absolute;
    top: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, transparent 100%);
    z-index: 10;
  }

  .player-status { display: flex; align-items: center; gap: 8px; }
  .live-dot { width: 8px; height: 8px; border-radius: 50%; background: #e53e3e; }
  .live-text { font-size: 11px; letter-spacing: 0.15em; font-weight: 500; color: #e53e3e; }

  /* Status colour by state */
  .player-status[data-state="live"] .live-dot { background: #e53e3e; animation: pulse-live 2s infinite; }
  .player-status[data-state="live"] .live-text { color: #e53e3e; }
  .player-status[data-state="connecting"] .live-dot,
  .player-status[data-state="reconnecting"] .live-dot { background: var(--gold); animation: pulse-amber 1.4s infinite; }
  .player-status[data-state="connecting"] .live-text,
  .player-status[data-state="reconnecting"] .live-text { color: var(--gold-light); }

  @keyframes pulse-live {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(229,62,62,0.6); }
    50% { opacity: 0.8; box-shadow: 0 0 0 4px rgba(229,62,62,0); }
  }
  @keyframes pulse-amber { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }

  .player-controls { display: flex; gap: 8px; }
  .player-btn {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--white);
    width: 36px; height: 36px; border-radius: 2px;
    cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .player-btn:hover { background: rgba(255,255,255,0.2); border-color: var(--gold); color: var(--gold); }

  /* Overlay pill over a soft bottom scrim; poster/view stays visible behind it. */
  .player-overlay {
    position: absolute; inset: 0;
    display: flex; align-items: flex-end; justify-content: center;
    padding-bottom: 18px;
    background: linear-gradient(0deg, rgba(8,8,8,0.5) 0%, transparent 45%);
    z-index: 6;
    pointer-events: none;
  }
  .player-overlay[hidden] { display: none; }

  .overlay-pill {
    display: flex; align-items: center; gap: 10px;
    background: rgba(8,8,8,0.72);
    border: 1px solid var(--border);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    padding: 8px 14px; border-radius: 999px;
  }
  .overlay-text { font-size: 11.5px; letter-spacing: 0.06em; color: var(--white); }
  .overlay-spinner {
    width: 13px; height: 13px; border-radius: 50%; flex: none;
    border: 2px solid rgba(245,240,232,0.25);
    border-top-color: var(--gold);
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  @media (prefers-reduced-motion: reduce) {
    .live-dot, .overlay-spinner { animation: none !important; }
  }
</style>

<script>
  function initPlayers() {
    document.querySelectorAll<HTMLDivElement>('.hls-player-wrap').forEach((wrap) => {
      if (wrap.dataset.hlsInit) return;
      wrap.dataset.hlsInit = '1';

      const video = wrap.querySelector<HTMLVideoElement>('.hls-video');
      const statusEl = wrap.querySelector<HTMLDivElement>('.player-status');
      const statusText = wrap.querySelector<HTMLSpanElement>('.live-text');
      const overlay = wrap.querySelector<HTMLDivElement>('.player-overlay');
      const overlayText = wrap.querySelector<HTMLSpanElement>('.overlay-text');
      const muteBtn = wrap.querySelector<HTMLButtonElement>('.mute-btn');
      const fullscreenBtn = wrap.querySelector<HTMLButtonElement>('.fullscreen-btn');
      const iconMuted = wrap.querySelector<SVGElement>('.icon-muted');
      const iconUnmuted = wrap.querySelector<SVGElement>('.icon-unmuted');
      const hlsUrl = wrap.dataset.hlsUrl;

      if (!video || !hlsUrl) return;

      const streamUrl = hlsUrl.endsWith('/') ? hlsUrl + 'index.m3u8' : hlsUrl;

      const MIN_DELAY = 4000;
      const MAX_DELAY = 15000;
      let hls: any = null;
      let retryTimer: number | undefined;
      let retryDelay = MIN_DELAY;
      let mediaRecoverTried = false;
      let destroyed = false;

      function setState(state: string, label: string) {
        if (statusEl) statusEl.dataset.state = state;
        if (statusText) statusText.textContent = label;
      }
      function showOverlay(msg: string) {
        if (overlayText) overlayText.textContent = msg;
        if (overlay) overlay.hidden = false;
      }
      function hideOverlay() { if (overlay) overlay.hidden = true; }

      function goLive() {
        retryDelay = MIN_DELAY;
        mediaRecoverTried = false;
        setState('live', 'LIVE');
        hideOverlay();
      }

      function teardownHls() {
        if (hls) { try { hls.destroy(); } catch (e) {} hls = null; }
      }

      // Keep the poster/view on screen with a soft "reconnecting" pill, and
      // retry with backoff so the player self-heals when the feed returns.
      function scheduleReconnect() {
        if (destroyed) return;
        setState('reconnecting', 'RECONNECTING');
        showOverlay('Live feed reconnecting…');
        clearTimeout(retryTimer);
        retryTimer = window.setTimeout(() => {
          if (destroyed || !document.contains(wrap)) return;
          teardownHls();
          try { video.removeAttribute('src'); video.load(); } catch (e) {}
          retryDelay = Math.min(Math.round(retryDelay * 1.5), MAX_DELAY);
          loadStream();
        }, retryDelay);
      }

      function tryHlsJs(): boolean {
        const Hls = (window as any).Hls;
        if (!Hls || !Hls.isSupported()) return false;
        teardownHls();
        hls = new Hls({ enableWorker: true, lowLatencyMode: true, maxBufferLength: 10, maxMaxBufferLength: 20 });
        hls.loadSource(streamUrl);
        hls.attachMedia(video);
        hls.on(Hls.Events.MANIFEST_PARSED, () => { goLive(); video.play().catch(() => {}); });
        hls.on(Hls.Events.ERROR, (_: any, data: any) => {
          if (!data || !data.fatal) return;
          if (data.type === Hls.ErrorTypes.MEDIA_ERROR && !mediaRecoverTried) {
            mediaRecoverTried = true;
            try { hls.recoverMediaError(); return; } catch (e) {}
          }
          scheduleReconnect();
        });
        return true;
      }

      function loadStream() {
        if (destroyed) return;
        if (video.canPlayType('application/vnd.apple.mpegurl')) {
          // Native HLS (Safari) — fall back to hls.js if it fails.
          video.src = streamUrl;
          video.addEventListener('loadeddata', goLive, { once: true });
          video.addEventListener('error', () => {
            try { video.removeAttribute('src'); video.load(); } catch (e) {}
            if (!tryHlsJs()) scheduleReconnect();
          }, { once: true });
          video.play().catch(() => {});
        } else if ((window as any).Hls) {
          if (!tryHlsJs()) scheduleReconnect();
        } else {
          const script = document.querySelector('script[src*="hls.js"]');
          if (script) script.addEventListener('load', () => loadStream(), { once: true });
          else scheduleReconnect();
        }
      }

      muteBtn?.addEventListener('click', () => {
        video.muted = !video.muted;
        if (iconMuted && iconUnmuted) {
          iconMuted.style.display = video.muted ? 'block' : 'none';
          iconUnmuted.style.display = video.muted ? 'none' : 'block';
        }
      });

      fullscreenBtn?.addEventListener('click', () => {
        if (document.fullscreenElement) document.exitFullscreen();
        else wrap.requestFullscreen?.();
      });

      // Stop retrying when Astro swaps the page out.
      document.addEventListener('astro:before-swap', () => {
        destroyed = true;
        clearTimeout(retryTimer);
        teardownHls();
      }, { once: true });

      setState('connecting', 'CONNECTING');
      showOverlay('Connecting to the live feed…');
      loadStream();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPlayers);
  } else {
    initPlayers();
  }
  document.addEventListener('astro:page-load', initPlayers);
</script>
