---
import Layout from '../layouts/Layout.astro';
import { cameras } from '../data/cameras';

// Hand-picked live feeds — 1 HLS (our server) + 5 YouTube live streams
const featuredFeeds = [
  { name: 'East Lewers Street', location: 'Waikiki, HI', region: 'Hawaii', type: 'hls' as const, url: 'https://cams.portofcams.com/east-lewers-st/index.m3u8', link: '/camera/east-lewers-st' },
  { name: 'Banzai Pipeline', location: 'North Shore, HI', region: 'Hawaii', type: 'youtube' as const, url: 'https://www.youtube.com/embed/VI8Wj5EwoRM', link: '/camera/east-lewers-st' },
  { name: 'Grand Teton', location: 'Jackson, WY', region: 'US Mainland', type: 'youtube' as const, url: 'https://www.youtube.com/embed/o4fKtgPVpoU', link: '/browse' },
  { name: 'Abbey Road', location: 'London, UK', region: 'International', type: 'youtube' as const, url: 'https://www.youtube.com/embed/XwXKJHgRM50', link: '/camera/abbey-road' },
  { name: 'Brooks Falls Bear Cam', location: 'Katmai, AK', region: 'Alaska', type: 'youtube' as const, url: 'https://www.youtube.com/embed/2UIA8xOVcOs', link: '/browse' },
  { name: 'Cannon Beach', location: 'Oregon Coast', region: 'Pacific NW', type: 'youtube' as const, url: 'https://www.youtube.com/embed/yHsRXs9WTuA', link: '/browse' },
];
---

<Layout title="PortOfCams Pro — Live Streaming for Venues, Events & Destinations" activeNav="home" includeHls={true}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content">
      <div class="hero-tag fade-up mono">Live Event Streaming Platform</div>
      <h1 class="display fade-up">
        Your venue.<br/>
        <em class="display-italic" style="color: var(--gold)">Always on.</em>
      </h1>
      <p class="hero-desc fade-up">
        Professional live video streaming for venues, events, and destinations. HD cameras installed free — your location streaming 24/7 to thousands of viewers.
      </p>
      <div class="hero-actions fade-up">
        <a href="/browse" class="btn-primary">Browse Live Feeds</a>
        <a href="/host" class="btn-secondary">Host a Camera</a>
      </div>
    </div>
  </section>

  <!-- Capability Strip -->
  <section class="capabilities">
    <div class="cap-inner">
      <div class="cap-item">
        <div class="cap-val display">24/7</div>
        <div class="cap-label mono">Live Streaming</div>
      </div>
      <div class="cap-divider"></div>
      <div class="cap-item">
        <div class="cap-val display">HD</div>
        <div class="cap-label mono">Video Quality</div>
      </div>
      <div class="cap-divider"></div>
      <div class="cap-item">
        <div class="cap-val display">Free</div>
        <div class="cap-label mono">Camera Install</div>
      </div>
      <div class="cap-divider"></div>
      <div class="cap-item">
        <div class="cap-val display">3</div>
        <div class="cap-label mono">Social Platforms</div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="what-section">
    <div class="section-inner">
      <p class="eyebrow mono fade-up">What We Do</p>
      <h2 class="display section-headline fade-up">
        Live cameras for<br/>
        <em class="display-italic" style="color: var(--gold)">every stage</em>
      </h2>
      <p class="section-body fade-up">
        Concerts, surf breaks, resort pools, downtown streets — we install and manage professional live cameras at your location. Viewers watch from anywhere in the world. You get exposure, engagement, and a marketing channel that never sleeps.
      </p>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="usecases">
    <div class="section-inner">
      <div class="usecase-grid">
        <div class="usecase-card">
          <div class="usecase-number mono">01</div>
          <h3 class="display">Venues &amp; Bars</h3>
          <p>Stream live music, happy hours, and packed dance floors. Let people see the energy before they walk in.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-number mono">02</div>
          <h3 class="display">Beach Resorts</h3>
          <p>Show off crystal blue water, perfect waves, and golden sunsets. Viewers become guests.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-number mono">03</div>
          <h3 class="display">Events &amp; Festivals</h3>
          <p>Broadcast your event live to the world. Build FOMO, sell tickets, grow your audience.</p>
        </div>
        <div class="usecase-card">
          <div class="usecase-number mono">04</div>
          <h3 class="display">Tourism &amp; Landmarks</h3>
          <p>Let travelers preview your destination in real-time. Live cameras drive bookings and foot traffic.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Cameras -->
  <section class="featured" id="featured">
    <div class="section-inner">
      <p class="eyebrow mono">Live Now</p>
      <div class="featured-header">
        <h2 class="display" style="font-size: clamp(40px, 5vw, 72px); max-width: 600px;">
          Streaming<br/><em class="display-italic" style="color: var(--gold)">right now</em>
        </h2>
        <a href="/browse" class="btn-secondary" style="flex-shrink: 0; align-self: flex-end;">View All Cameras</a>
      </div>
      <div class="featured-grid">
        {featuredFeeds.map((feed) => (
          <a href={feed.link} class="featured-card" data-stream={feed.type === 'hls' ? feed.url : ''}>
            <div class="featured-preview">
              {feed.type === 'hls' ? (
                <video class="featured-video" muted playsinline></video>
              ) : (
                <iframe class="featured-embed" src={`${feed.url}?autoplay=1&mute=1&controls=0&loop=1&modestbranding=1&playsinline=1&rel=0&showinfo=0`} allow="accelerometer; autoplay; encrypted-media; gyroscope" loading="lazy"></iframe>
              )}
              <div class="featured-overlay"></div>
              <div class="featured-live">
                <span class="featured-live-dot"></span>
                <span class="mono">LIVE</span>
              </div>
              <div class="featured-region mono">{feed.region}</div>
            </div>
            <div class="featured-info">
              <h3>{feed.name}</h3>
              <p>{feed.location}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how" id="how">
    <div class="section-inner">
      <p class="eyebrow mono">How It Works</p>
      <h2 class="display" style="font-size: clamp(40px,5vw,72px); max-width: 700px;">
        Three steps to <em class="display-italic" style="color: var(--gold)">going live</em>
      </h2>
      <div class="how-grid">
        <div class="how-card">
          <div class="how-number">01</div>
          <h3>We Install</h3>
          <p>We ship and install a professional HD camera at your venue — completely free. You just need WiFi.</p>
        </div>
        <div class="how-card">
          <div class="how-number">02</div>
          <h3>You Stream</h3>
          <p>Your location goes live on PortOfCams, reaching thousands of viewers every day. We handle all the tech.</p>
        </div>
        <div class="how-card">
          <div class="how-number">03</div>
          <h3>You Grow</h3>
          <p>AI-generated timelapse clips auto-post to YouTube, Instagram, and TikTok — free social content, daily.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Big Statement -->
  <section class="statement">
    <div class="section-inner" style="text-align: center;">
      <h2 class="display fade-up" style="font-size: clamp(48px, 7vw, 100px); max-width: 900px; margin: 0 auto 40px;">
        Your camera.<br/>
        Our platform.<br/>
        <em class="display-italic" style="color: var(--gold)">Their audience.</em>
      </h2>
      <p style="color: var(--muted); font-size: 20px; line-height: 1.7; max-width: 520px; margin: 0 auto 48px;">
        Every beautiful moment at your location becomes shareable content — captured, clipped, and posted automatically.
      </p>
      <a href="/host" class="btn-primary">Get a Free Camera</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 120px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 50% at 50% 40%, rgba(201,168,76,0.06) 0%, transparent 70%),
      linear-gradient(180deg, #080808 0%, #0a0905 100%);
  }

  .hero-content {
    position: relative;
    max-width: 900px;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 1px;
    margin-bottom: 40px;
    width: fit-content;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero h1 {
    font-size: clamp(64px, 10vw, 140px);
    margin-bottom: 40px;
    position: relative;
  }

  .hero-desc {
    font-size: 20px;
    color: var(--muted);
    max-width: 560px;
    line-height: 1.7;
    margin: 0 auto 48px;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Capability Strip */
  .capabilities {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--deep);
  }

  .cap-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 48px;
  }

  .cap-item { text-align: center; }

  .cap-val {
    font-size: clamp(36px, 4vw, 56px);
    color: var(--gold);
    line-height: 1;
    margin-bottom: 8px;
  }

  .cap-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .cap-divider {
    width: 1px;
    height: 48px;
    background: var(--border);
  }

  /* What We Do */
  .what-section {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .what-section .section-inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
  }

  .section-headline {
    font-size: clamp(40px, 6vw, 80px);
    margin-bottom: 32px;
    max-width: 700px;
  }

  .section-body {
    font-size: 20px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 600px;
    text-align: center;
  }

  /* Use Cases */
  .usecases {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .usecase-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .usecase-card {
    background: var(--deep);
    padding: 56px 48px;
    transition: background 0.3s;
  }

  .usecase-card:hover { background: var(--surface); }

  .usecase-number {
    font-size: 11px;
    letter-spacing: 0.15em;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .usecase-card h3 {
    font-size: clamp(24px, 3vw, 36px);
    margin-bottom: 12px;
  }

  .usecase-card p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
    max-width: 360px;
  }

  /* Featured Cameras */
  .featured {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .featured-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .featured-card {
    background: var(--deep);
    text-decoration: none;
    color: var(--white);
    transition: background 0.3s;
  }

  .featured-card:hover { background: var(--surface); }

  .featured-preview {
    aspect-ratio: 16 / 10;
    background: var(--surface);
    position: relative;
    overflow: hidden;
  }

  .featured-video,
  .featured-embed {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: none;
    pointer-events: none;
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.5) 100%);
  }

  .featured-live {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(0,0,0,0.6);
    padding: 3px 8px;
    border-radius: 2px;
    border: 1px solid rgba(229,62,62,0.3);
  }

  .featured-live-dot {
    width: 5px;
    height: 5px;
    background: #e53e3e;
    border-radius: 50%;
    animation: pulse-featured 2s infinite;
  }

  @keyframes pulse-featured {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .featured-live span:last-child {
    font-size: 8px;
    letter-spacing: 0.15em;
    color: #e53e3e;
  }

  .featured-region {
    position: absolute;
    bottom: 10px;
    right: 10px;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(0,0,0,0.6);
    padding: 3px 8px;
    border-radius: 2px;
    border: 1px solid rgba(201,168,76,0.2);
  }

  .featured-info {
    padding: 20px 24px;
  }

  .featured-info h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 600;
    margin-bottom: 4px;
    transition: color 0.3s;
  }

  .featured-card:hover .featured-info h3 { color: var(--gold); }

  .featured-info p {
    font-size: 14px;
    color: var(--muted);
  }

  /* How It Works */
  .how {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 64px;
  }

  .how-card {
    background: var(--surface);
    padding: 56px 44px;
    position: relative;
  }

  .how-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 80px;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: 24px;
  }

  .how-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .how-card p {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* Big Statement */
  .statement {
    border-top: 1px solid var(--border);
    background: var(--deep);
    position: relative;
    overflow: hidden;
  }

  .statement::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 50% 50%, rgba(201,168,76,0.05) 0%, transparent 70%);
  }

  .statement .section-inner {
    padding-top: 160px;
    padding-bottom: 160px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 100px 24px 60px; }
    .hero-desc { font-size: 17px; }
    .cap-inner { flex-wrap: wrap; gap: 32px; padding: 40px 24px; }
    .cap-divider { display: none; }
    .cap-inner { justify-content: space-around; }
    .usecase-grid { grid-template-columns: 1fr; }
    .usecase-card { padding: 40px 28px; }
    .featured-grid { grid-template-columns: 1fr; }
    .how-grid { grid-template-columns: 1fr; }
    .section-body { font-size: 17px; }
    .statement .section-inner { padding-top: 100px; padding-bottom: 100px; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    // Only lazy-load HLS cards (Windy embeds load themselves via iframe)
    const hlsCards = document.querySelectorAll('.featured-card[data-stream]');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const card = entry.target;
        const video = card.querySelector('.featured-video');
        const url = card.dataset.stream;
        if (!url || !video || card.dataset.loaded) return;
        card.dataset.loaded = 'true';
        observer.unobserve(card);

        if (video.canPlayType('application/vnd.apple.mpegurl')) {
          video.src = url;
          video.play().catch(() => {});
        } else if (window.Hls && Hls.isSupported()) {
          const hls = new Hls({ startLevel: 0, capLevelToPlayerSize: true, maxBufferLength: 5 });
          hls.loadSource(url);
          hls.attachMedia(video);
          hls.on(Hls.Events.MANIFEST_PARSED, () => video.play().catch(() => {}));
          hls.on(Hls.Events.ERROR, (_, data) => {
            if (data.fatal) hls.destroy();
          });
        }
      });
    }, { rootMargin: '300px' });
    hlsCards.forEach(card => {
      if (card.dataset.stream) observer.observe(card);
    });
  });
</script>
