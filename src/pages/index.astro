---
import Layout from '../layouts/Layout.astro';
import { cameras } from '../data/cameras';

const featuredCameras = cameras.slice(0, 6);
---

<Layout title="PortOfCams — Live Cameras from Around the World" activeNav="home">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-lines"></div>
    <div style="position:relative;">
      <div class="hero-tag fade-up mono">Live Cameras Worldwide</div>
      <h1 class="display fade-up">
        See the World.<br/>
        <em class="display-italic" style="color: var(--gold)">Live.</em>
      </h1>
      <div class="hero-sub fade-up">
        <p class="hero-desc">
          Curated live camera feeds from iconic locations across the globe — street views, beaches, landmarks, and traffic. All free, all live, always on.
        </p>
        <div class="hero-actions">
          <a href="/browse" class="btn-primary">Browse Cameras</a>
          <a href="#featured" class="btn-secondary">See Featured</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ticker -->
  <div class="ticker">
    <div class="ticker-inner">
      <div class="ticker-item"><span>*</span> Live Streams</div>
      <div class="ticker-item"><span>*</span> Street Views</div>
      <div class="ticker-item"><span>*</span> Beach Cams</div>
      <div class="ticker-item"><span>*</span> Traffic Cameras</div>
      <div class="ticker-item"><span>*</span> Landmark Views</div>
      <div class="ticker-item"><span>*</span> Global Coverage</div>
      <div class="ticker-item"><span>*</span> Live Streams</div>
      <div class="ticker-item"><span>*</span> Street Views</div>
      <div class="ticker-item"><span>*</span> Beach Cams</div>
      <div class="ticker-item"><span>*</span> Traffic Cameras</div>
      <div class="ticker-item"><span>*</span> Landmark Views</div>
      <div class="ticker-item"><span>*</span> Global Coverage</div>
    </div>
  </div>

  <!-- Featured Cameras -->
  <section class="featured" id="featured">
    <div class="section-inner">
      <div class="section-label">Featured Cameras</div>
      <div class="featured-header">
        <h2 class="display" style="font-size: clamp(40px, 4vw, 64px); max-width: 600px;">
          Popular<br/><em class="display-italic" style="color: var(--gold)">right now</em>
        </h2>
        <a href="/browse" class="btn-secondary" style="flex-shrink: 0; align-self: flex-end;">View All Cameras</a>
      </div>
      <div class="featured-grid">
        {featuredCameras.map((cam) => (
          <a href={`/camera/${cam.id}`} class="featured-card">
            <div class="featured-preview">
              <div class="featured-overlay"></div>
              <div class="featured-live">
                <span class="featured-live-dot"></span>
                <span class="mono">LIVE</span>
              </div>
              <div class="featured-region mono">{cam.region}</div>
            </div>
            <div class="featured-info">
              <h3>{cam.name}</h3>
              <p>{cam.location}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="how" id="how">
    <div class="section-inner">
      <div class="section-label">How It Works</div>
      <h2 class="display" style="font-size: clamp(40px,4vw,64px); max-width: 600px;">
        Simple <em class="display-italic" style="color: var(--gold)">& free</em>
      </h2>
      <div class="how-grid">
        <div class="how-card">
          <div class="how-number">01</div>
          <h3>Browse Cameras</h3>
          <p>Explore our curated collection of live cameras from around the world. Filter by region, type, or browse them all.</p>
        </div>
        <div class="how-card">
          <div class="how-number">02</div>
          <h3>Watch Live</h3>
          <p>Click any camera to open a full-screen live stream. All feeds are in real-time with low latency HLS delivery.</p>
        </div>
        <div class="how-card">
          <div class="how-number">03</div>
          <h3>Discover More</h3>
          <p>Find related cameras and explore new locations. We're always adding new feeds from iconic spots worldwide.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="section-inner" style="padding-top: 80px; padding-bottom: 80px;">
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-number">{cameras.length}</div>
          <div class="stat-label mono">Live Cameras</div>
        </div>
        <div class="stat">
          <div class="stat-number">3</div>
          <div class="stat-label mono">Regions</div>
        </div>
        <div class="stat">
          <div class="stat-number">24/7</div>
          <div class="stat-label mono">Always Live</div>
        </div>
        <div class="stat">
          <div class="stat-number">Free</div>
          <div class="stat-label mono">No Account Needed</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Premium Upsell -->
  <section class="premium-upsell">
    <div class="section-inner">
      <div class="upsell-card">
        <div class="upsell-badge mono">Premium</div>
        <h2 class="display" style="font-size: clamp(28px, 3vw, 44px); margin-bottom: 16px;">
          Want HD, no ads &amp; <em class="display-italic" style="color: var(--gold)">every camera</em>?
        </h2>
        <p style="color: var(--muted); font-size: 15px; line-height: 1.7; max-width: 500px; margin-bottom: 32px;">
          Upgrade to Premium for full HD streams, ad-free viewing, timelapse archives, and access to every camera on the platform. Starting at $9.99/month.
        </p>
        <a href="/premium" class="btn-primary">Go Premium</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="section-inner" style="text-align: center;">
      <h2 class="display" style="font-size: clamp(40px, 5vw, 72px); margin-bottom: 20px;">
        Start <em class="display-italic" style="color: var(--gold)">watching</em>
      </h2>
      <p style="color: var(--muted); font-size: 17px; line-height: 1.7; max-width: 480px; margin: 0 auto 40px;">
        Explore live cameras from beaches, city streets, and landmarks around the world. No signup required.
      </p>
      <a href="/browse" class="btn-primary">Browse All Cameras</a>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 40%, rgba(201,168,76,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 60% at 20% 60%, rgba(201,168,76,0.04) 0%, transparent 60%),
      linear-gradient(180deg, #080808 0%, #0a0905 100%);
  }

  .hero-lines {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 80px);
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 16px;
    border-radius: 1px;
    margin-bottom: 32px;
    width: fit-content;
  }

  .hero-tag::before {
    content: '';
    width: 6px;
    height: 6px;
    background: var(--gold);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero h1 {
    font-size: clamp(64px, 9vw, 140px);
    max-width: 900px;
    margin-bottom: 40px;
    position: relative;
  }

  .hero h1 em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 300;
    color: var(--gold);
  }

  .hero-sub {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 40px;
    flex-wrap: wrap;
  }

  .hero-desc {
    font-size: 17px;
    color: var(--muted);
    max-width: 440px;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-shrink: 0;
  }

  /* Ticker */
  .ticker {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 14px 0;
    overflow: hidden;
    background: var(--deep);
  }

  .ticker-inner {
    display: flex;
    gap: 60px;
    animation: ticker 20s linear infinite;
    white-space: nowrap;
  }

  .ticker-item {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    flex-shrink: 0;
  }

  .ticker-item span { color: var(--gold); margin-right: 20px; }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Featured Cameras */
  .featured {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .featured-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .featured-card {
    background: var(--deep);
    text-decoration: none;
    color: var(--white);
    transition: background 0.3s;
  }

  .featured-card:hover { background: var(--surface); }

  .featured-preview {
    aspect-ratio: 16 / 10;
    background: var(--surface);
    position: relative;
    overflow: hidden;
    background-image:
      repeating-linear-gradient(
        0deg,
        rgba(255,255,255,0.01) 0px,
        rgba(255,255,255,0.01) 1px,
        transparent 1px,
        transparent 4px
      );
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 40%, transparent 60%, rgba(0,0,0,0.5) 100%);
  }

  .featured-live {
    position: absolute;
    top: 10px;
    left: 10px;
    display: flex;
    align-items: center;
    gap: 5px;
    background: rgba(0,0,0,0.6);
    padding: 3px 8px;
    border-radius: 2px;
    border: 1px solid rgba(229,62,62,0.3);
  }

  .featured-live-dot {
    width: 5px;
    height: 5px;
    background: #e53e3e;
    border-radius: 50%;
    animation: pulse-featured 2s infinite;
  }

  @keyframes pulse-featured {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .featured-live span:last-child {
    font-size: 8px;
    letter-spacing: 0.15em;
    color: #e53e3e;
  }

  .featured-region {
    position: absolute;
    bottom: 10px;
    right: 10px;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(0,0,0,0.6);
    padding: 3px 8px;
    border-radius: 2px;
    border: 1px solid rgba(201,168,76,0.2);
  }

  .featured-info {
    padding: 16px 20px;
  }

  .featured-info h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 4px;
    transition: color 0.3s;
  }

  .featured-card:hover .featured-info h3 { color: var(--gold); }

  .featured-info p {
    font-size: 13px;
    color: var(--muted);
  }

  /* How It Works */
  .how {
    border-top: 1px solid var(--border);
  }

  .how-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: 60px;
  }

  .how-card {
    background: var(--surface);
    padding: 48px 40px;
    position: relative;
  }

  .how-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 80px;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.15;
    line-height: 1;
    margin-bottom: 24px;
  }

  .how-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 26px;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .how-card p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
  }

  /* Stats */
  .stats {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .stat {
    background: var(--surface);
    padding: 48px 32px;
    text-align: center;
  }

  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px;
    font-weight: 600;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 8px;
  }

  .stat-label {
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Premium Upsell */
  .premium-upsell {
    border-top: 1px solid var(--border);
    background: var(--surface);
  }

  .upsell-card {
    border: 1px solid rgba(201,168,76,0.2);
    background: linear-gradient(135deg, rgba(201,168,76,0.06) 0%, rgba(201,168,76,0.02) 100%);
    padding: 60px 48px;
    position: relative;
    overflow: hidden;
  }

  .upsell-card::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .upsell-badge {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--gold);
    padding: 4px 12px;
    display: inline-block;
    margin-bottom: 24px;
  }

  /* CTA */
  .cta-section {
    border-top: 1px solid var(--border);
    background: var(--deep);
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 50% 50%, rgba(201,168,76,0.06) 0%, transparent 70%);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero { padding: 0 24px 60px; }
    .featured-grid { grid-template-columns: 1fr; }
    .how-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
