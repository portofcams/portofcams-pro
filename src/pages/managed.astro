---
import Layout from '../layouts/Layout.astro';

// Managed Marketing Cam — the premium, done-for-you tier ABOVE the $50/mo co-branded host program.
// Buyer: revenue-driven Hawaii venues (hotels, marinas, resorts, beachfront F&B) that want it handled,
// broadcast-grade, with monthly social content — not the DIY plug-it-in-yourself host.
const tiers = [
  {
    name: 'Vista', price: '149', install: '1,490', badge: false,
    lens: 'Single 4K marine-rated camera', best: 'Storefronts, beach bars, single-slip marina views',
    feats: [
      'Broadcast-grade 4K camera, marine-sealed for salt air',
      'Professional install — we mount and aim it, you touch nothing',
      '24/7 hosting on our Hawaii streaming network',
      'Monthly branded social clips cut from your feed',
      'One-line co-branded player for your own website',
      'A featured page on the Port of Cams network',
    ],
  },
  {
    name: 'Panorama', price: '199', install: '1,790', badge: true,
    lens: 'Dual-lens 180° camera', best: 'Resorts, harbors, wide bays and beachfronts',
    feats: [
      'Everything in Vista, plus:',
      'Dual-lens 180° sweep — whole bay, one feed',
      'Priority placement on the network',
      'A wider 180° frame — more to cut into your monthly clips',
    ],
  },
];
const includedAll = [
  ['Pro install', 'A person comes, mounts a marine-rated camera the right way, and aims it. No cable in a box for your staff to figure out.'],
  ['Managed hosting', 'Runs on the same Hawaii streaming stack behind PortOfCams. Uptime watched. If it drops, we know before you do.'],
  ['Your player, your site', 'A co-branded live player embeds on your website with one line of code. Your brand and ours.'],
  ['Monthly social clips', 'We cut branded timelapses and short reels from your feed every month — ready to post. Sunset over the harbor, surf filling in, the room at golden hour.'],
  ['Salt-air service', 'Quarterly on-site check. Hardware swap-not-fix — if a camera fails, it gets replaced, not diagnosed for a week.'],
  ['Network exposure', 'Your view joins the Port of Cams network — a live backlink to your site and a stream of new eyes from people watching the islands.'],
];
const faqs = [
  ['How is this different from the $50/mo co-branded host?', 'The co-branded plan is set-it-up-yourself: we ship a camera, you plug it in, we host the feed. Managed is done-for-you and broadcast-grade — a professional marine camera we install and maintain, plus monthly social content and on-site service. Two different products for two different venues. If you want the lighter option, start on the Host page.'],
  ['What does it cost to start?', 'Professional install is $1,490 for Vista or $1,790 for Panorama, billed at signup along with your first month. After that it\'s simple month-to-month at your plan rate — cancel anytime with 30 days\' notice.'],
  ['Where can the camera point?', 'Public views only — your beach, your harbor, your storefront, the surf. We do not point cameras at anything privacy-sensitive, and the view is yours to approve before we mount anything.'],
  ['Do we own the footage?', 'You and Port of Cams both hold rights to the live feed, recordings, and timelapses. Use the footage freely in your own marketing — that is the point.'],
  ['What if our IT locks down the network?', 'The camera can run fully off your network on its own cellular or Starlink connection — nothing to route, nothing for your IT to approve. Add-on at hardware cost plus $49/mo.'],
  ['Already have a camera on the property?', 'If a working RTSP-capable camera is already mounted — many venues have one left over from an AV project — we can ingest, brand, host, and monitor that feed for $99/mo with no install at all. Mention the model when you reach out and we will confirm compatibility.'],
];
---

<Layout
  title="Managed Marketing Cam — Port of Cams Pro"
  description="A broadcast-grade live camera on your Hawaii waterfront, installed and maintained for you, with monthly social clips. For hotels, marinas, and resorts. From $149/mo."
  activeNav=""
>
  <main class="mgd">

    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <div class="eyebrow mono">Port of Cams Pro &middot; Managed</div>
        <h1>Your Hawaiʻi view,<br /><em>broadcast-grade</em> and handled for you.</h1>
        <p class="lede">
          A professional live camera on your waterfront — installed, hosted, and maintained by us,
          with fresh social clips every month. Built for hotels, marinas, and resorts that would
          rather run their business than run a webcam.
        </p>
        <div class="hero-cta">
          <a href="#pilot" class="btn-gold">Get started</a>
          <a href="#included" class="btn-ghost">What's included</a>
        </div>
        <div class="hero-note mono">Prefer to set it up yourself? The <a href="/host">$50/mo co-branded host</a> plan has you covered.</div>
      </div>
    </section>

    <!-- Proof strip -->
    <section class="strip">
      <div class="strip-item"><span class="sv">4K</span><span class="sl mono">Marine-sealed</span></div>
      <div class="strip-div"></div>
      <div class="strip-item"><span class="sv">Done</span><span class="sl mono">For you</span></div>
      <div class="strip-div"></div>
      <div class="strip-item"><span class="sv">Monthly</span><span class="sl mono">Social clips</span></div>
      <div class="strip-div"></div>
      <div class="strip-item"><span class="sv">No lock-in</span><span class="sl mono">Month-to-month</span></div>
    </section>

    <!-- Why -->
    <section class="why">
      <h2>A live cam is the cheapest salesperson your view will ever hire.</h2>
      <p>
        People book the ocean they can see. A live feed of your beach, your harbor, or your break
        turns a browser into a booking — and turns your best asset, the view you already own, into
        marketing that runs 24 hours a day. The only reason more Hawaiʻi venues don't have one is
        that the good ones are a hassle to buy, install, and keep alive in the salt.
      </p>
      <p class="why-kick">That's the whole job we take off your plate.</p>
    </section>

    <!-- Tiers -->
    <section class="tiers" id="pricing">
      <div class="sec-head"><span class="mono tag">Two cameras</span><h2>Pick the view.</h2></div>
      <div class="tier-grid">
        {tiers.map((t) => (
          <div class:list={["tier", { feature: t.badge }]}>
            {t.badge && <div class="tier-badge mono">Most popular</div>}
            <div class="tier-name">{t.name}</div>
            <div class="tier-lens mono">{t.lens}</div>
            <div class="tier-price">
              <span class="tp-amt">${t.price}</span><span class="tp-per">/mo</span>
            </div>
            <div class="tier-install mono">+ ${t.install} one-time pro install</div>
            <div class="tier-best">{t.best}</div>
            <ul class="tier-feats">
              {t.feats.map((f) => <li>{f}</li>)}
            </ul>
            <a href="#pilot" class="tier-btn">Get started</a>
          </div>
        ))}
      </div>
      <div class="tier-compare">
        <p class="tc-line">A managed tourism cam runs about $149/mo elsewhere — on a 12-month contract, with camera and install billed on top. <strong>Vista matches it at $149, Panorama is $199</strong> for the dual-lens — both <em>month-to-month</em>, with the monthly social clips <em>already included</em>.</p>
      </div>
      <p class="tier-fine mono">Off-grid cellular / Starlink option: hardware cost + $49/mo. No long contracts — monthly, cancel anytime.</p>
    </section>

    <!-- Included -->
    <section class="included" id="included">
      <div class="sec-head"><span class="mono tag">Every plan</span><h2>What "managed" actually means.</h2></div>
      <div class="inc-grid">
        {includedAll.map(([h, b], i) => (
          <div class="inc">
            <div class="inc-n mono">{String(i + 1).padStart(2, '0')}</div>
            <h3>{h}</h3>
            <p>{b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Who -->
    <section class="who">
      <div class="sec-head"><span class="mono tag">Built for</span><h2>Venues with a view worth watching.</h2></div>
      <div class="who-row">
        <div class="who-card"><h3>Hotels &amp; resorts</h3><p>A live beachfront on your homepage — the booking-page hero that never needs a photographer.</p></div>
        <div class="who-card"><h3>Marinas &amp; harbors</h3><p>Slip-holders check conditions, visitors watch the boats, and your marina stays top-of-mind.</p></div>
        <div class="who-card"><h3>Surf &amp; dive shops</h3><p>A live look at the break is the reason surfers open your site every morning before dawn.</p></div>
        <div class="who-card"><h3>Beachfront F&amp;B</h3><p>Sunset over your lanai, streaming. The table books itself.</p></div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" id="faq">
      <div class="sec-head"><span class="mono tag">Questions</span><h2>Fair questions, straight answers.</h2></div>
      <div class="faq-list">
        {faqs.map(([q, a]) => (
          <details class="faq-item">
            <summary>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Signup / CTA -->
    <section class="pilot" id="pilot">
      <div class="pilot-inner">
        <div class="mono tag gold">Get started</div>
        <h2>Ready to go live? We install this week.</h2>
        <p>
          Professional install and your first month are billed at signup — $1,490 for Vista or $1,790
          for Panorama, plus your plan rate. Most venues are live within a week. After that it's simple
          month-to-month — cancel anytime with 30 days' notice.
        </p>

        <form id="pilotForm" class="pform" novalidate>
          <div class="pform-row">
            <div class="pform-field">
              <label for="pfVenue" class="mono">Venue</label>
              <input id="pfVenue" name="business_name" type="text" required maxlength="120" placeholder="Venue or business name" />
            </div>
            <div class="pform-field">
              <label for="pfName" class="mono">Your name</label>
              <input id="pfName" name="name" type="text" required maxlength="120" placeholder="First and last" />
            </div>
          </div>
          <div class="pform-row">
            <div class="pform-field">
              <label for="pfEmail" class="mono">Email</label>
              <input id="pfEmail" name="email" type="email" required maxlength="200" placeholder="you@yourvenue.com" />
            </div>
            <div class="pform-field">
              <label for="pfPhone" class="mono">Phone <span class="opt">optional</span></label>
              <input id="pfPhone" name="phone" type="tel" maxlength="40" placeholder="(808) ..." />
            </div>
          </div>
          <div class="pform-row">
            <div class="pform-field">
              <label for="pfLocation" class="mono">Where is the view?</label>
              <input id="pfLocation" name="location" type="text" required maxlength="200" placeholder="e.g. Ala Wai Harbor, Waikīkī" />
            </div>
            <div class="pform-field">
              <label for="pfPlan" class="mono">Plan</label>
              <select id="pfPlan" name="plan">
                <option value="not-sure" selected>Not sure yet — advise me</option>
                <option value="vista">Vista — $149/mo</option>
                <option value="panorama">Panorama — $199/mo</option>
                <option value="byo-cam">I already have a camera — $99/mo hosting</option>
              </select>
            </div>
          </div>
          <div class="pform-field">
            <label for="pfView" class="mono">What should the camera see? <span class="opt">optional</span></label>
            <input id="pfView" name="view" type="text" maxlength="300" placeholder="e.g. the break off our seawall, the fuel dock, sunset over the lanai" />
          </div>
          <button type="submit" class="btn-gold pform-btn" id="pfSubmit">Get started</button>
          <div class="pform-error mono" id="pfError" hidden></div>
        </form>

        <div class="pform-success" id="pfSuccess" hidden>
          <h3>Got it — mahalo.</h3>
          <p>Your request is in. A real person (the one who installs the cameras) will reply within one business day.</p>
        </div>

        <div class="pilot-fine mono">Prefer email? <a href="mailto:portofcams@gmail.com?subject=Managed%20Marketing%20Cam%20inquiry">portofcams@gmail.com</a> &middot; Serving Oʻahu now &middot; neighbor islands by arrangement &middot; a Port of Cams Pro service</div>
      </div>
    </section>

  </main>

  <style>
    .mgd { --edge: rgba(245,240,232,0.10); color: var(--white); overflow: hidden; }
    .mgd section { padding-left: 24px; padding-right: 24px; }
    .mgd h1, .mgd h2, .mgd h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 600; letter-spacing: -0.01em; }
    .mgd .mono { font-family: 'DM Mono', monospace; }
    .mgd p, .mgd li, .mgd .tier-best, .mgd .who-card p { font-family: 'DM Sans', system-ui, sans-serif; }
    .mgd em { font-style: italic; color: var(--gold); }

    /* Hero */
    .hero { padding-top: 132px; padding-bottom: 40px; max-width: 1000px; margin: 0 auto; text-align: center; }
    .hero-inner { display: flex; flex-direction: column; align-items: center; }
    .eyebrow { font-size: 12px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 22px; }
    .hero h1 { font-size: clamp(40px, 8vw, 76px); line-height: 1.02; margin: 0; text-wrap: balance; }
    .lede { font-size: clamp(17px, 2.4vw, 20px); line-height: 1.6; color: rgba(245,240,232,0.72); max-width: 60ch; margin: 26px 0 0; }
    .hero-cta { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin: 34px 0 0; }
    .hero-note { font-size: 12.5px; color: var(--muted); margin-top: 20px; }
    .hero-note a { color: var(--gold); }

    .btn-gold { background: var(--gold); color: #1a1508; text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; padding: 14px 26px; border-radius: 8px; transition: transform .15s, box-shadow .15s; }
    .btn-gold:hover { transform: translateY(-1px); box-shadow: 0 8px 24px var(--gold-dim); }
    .btn-ghost { border: 1px solid var(--edge); color: var(--white); text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; padding: 14px 26px; border-radius: 8px; }
    .btn-ghost:hover { border-color: var(--gold); }

    /* Strip */
    .strip { display: flex; align-items: center; justify-content: center; gap: clamp(14px, 4vw, 46px); max-width: 1000px; margin: 0 auto; padding-top: 34px; padding-bottom: 34px; border-top: 1px solid var(--edge); border-bottom: 1px solid var(--edge); flex-wrap: wrap; }
    .strip-item { display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .strip .sv { font-family: 'Cormorant Garamond', serif; font-size: 30px; color: var(--gold); line-height: 1; }
    .strip .sl { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }
    .strip-div { width: 1px; height: 34px; background: var(--edge); }

    /* Why */
    .why { max-width: 780px; margin: 0 auto; padding-top: 88px; text-align: center; }
    .why h2 { font-size: clamp(28px, 5vw, 44px); line-height: 1.1; margin: 0 auto; max-width: 16ch; text-wrap: balance; }
    .why p { font-size: 17px; line-height: 1.65; color: rgba(245,240,232,0.68); max-width: 58ch; margin: 22px auto 0; }
    .why-kick { color: var(--gold) !important; font-weight: 500; }

    .sec-head { max-width: 1000px; margin: 0 auto 34px; text-align: center; }
    .sec-head .tag { display: inline-block; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
    .sec-head h2 { font-size: clamp(28px, 5vw, 44px); margin: 0; }

    /* Tiers */
    .tiers { padding-top: 96px; }
    .tier-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; max-width: 860px; margin: 0 auto; }
    .tier { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 32px 28px; position: relative; }
    .tier.feature { border-color: var(--gold); box-shadow: 0 20px 60px -30px var(--gold-dim); }
    .tier-badge { position: absolute; top: -11px; left: 28px; background: var(--gold); color: #1a1508; font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; border-radius: 20px; }
    .tier-name { font-family: 'Cormorant Garamond', serif; font-size: 30px; font-weight: 600; }
    .tier-lens { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .tier-price { margin: 20px 0 2px; display: flex; align-items: baseline; gap: 3px; }
    .tp-amt { font-family: 'Cormorant Garamond', serif; font-size: 52px; font-weight: 600; color: var(--gold); line-height: 1; }
    .tp-per { color: var(--muted); font-family: 'DM Sans', sans-serif; }
    .tier-install { font-size: 12.5px; color: rgba(245,240,232,0.55); }
    .tier-best { font-size: 13.5px; color: rgba(245,240,232,0.6); margin: 16px 0; padding-bottom: 16px; border-bottom: 1px solid var(--border); font-style: italic; }
    .tier-feats { list-style: none; padding: 0; margin: 0 0 26px; display: grid; gap: 11px; }
    .tier-feats li { font-size: 14px; line-height: 1.45; color: rgba(245,240,232,0.82); padding-left: 22px; position: relative; }
    .tier-feats li::before { content: "›"; position: absolute; left: 4px; color: var(--gold); }
    .tier-btn { display: block; text-align: center; background: transparent; border: 1px solid var(--gold); color: var(--gold); text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 14.5px; padding: 12px; border-radius: 8px; transition: background .15s, color .15s; }
    .tier.feature .tier-btn { background: var(--gold); color: #1a1508; }
    .tier-btn:hover { background: var(--gold); color: #1a1508; }
    .tier-fine { text-align: center; font-size: 12px; color: var(--muted); max-width: 620px; margin: 26px auto 0; line-height: 1.6; }
    .tier-compare { max-width: 640px; margin: 32px auto 0; padding: 18px 26px; border: 1px solid var(--border); border-radius: 12px; background: var(--surface); }
    .tier-compare .tc-line { font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.6; color: rgba(245,240,232,0.72); text-align: center; margin: 0; }
    .tier-compare strong { color: var(--white); font-weight: 600; }

    /* Included */
    .included { padding-top: 100px; }
    .inc-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; max-width: 1000px; margin: 0 auto; background: var(--border); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .inc { background: var(--deep); padding: 30px 26px; }
    .inc-n { font-size: 12px; color: var(--gold); letter-spacing: 0.1em; margin-bottom: 14px; }
    .inc h3 { font-size: 21px; margin: 0 0 8px; }
    .inc p { font-size: 14px; line-height: 1.55; color: rgba(245,240,232,0.62); margin: 0; }

    /* Who */
    .who { padding-top: 100px; }
    .who-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; max-width: 1000px; margin: 0 auto; }
    .who-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 24px 22px; }
    .who-card h3 { font-size: 20px; margin: 0 0 8px; color: var(--gold-light); }
    .who-card p { font-size: 13.5px; line-height: 1.5; color: rgba(245,240,232,0.6); margin: 0; }

    /* FAQ */
    .faq { padding-top: 100px; }
    .faq-list { max-width: 720px; margin: 0 auto; display: grid; gap: 10px; }
    .faq-item { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 0 22px; }
    .faq-item summary { cursor: pointer; list-style: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15.5px; color: var(--white); padding: 18px 0; position: relative; padding-right: 28px; }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-item summary::after { content: "+"; position: absolute; right: 2px; top: 50%; transform: translateY(-50%); color: var(--gold); font-size: 20px; font-family: 'DM Mono', monospace; }
    .faq-item[open] summary::after { content: "–"; }
    .faq-item p { font-size: 14.5px; line-height: 1.6; color: rgba(245,240,232,0.68); margin: 0; padding: 0 0 18px; }

    /* Pilot */
    .pilot { padding-top: 104px; padding-bottom: 100px; }
    .pilot-inner { max-width: 720px; margin: 0 auto; background: linear-gradient(160deg, var(--surface), var(--deep)); border: 1px solid var(--gold); border-radius: 20px; padding: 48px 40px; text-align: center; box-shadow: 0 30px 80px -40px var(--gold-dim); }
    .pilot .tag { display: inline-block; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
    .pilot h2 { font-size: clamp(28px, 5vw, 42px); margin: 0 0 16px; text-wrap: balance; }
    .pilot p { font-size: 16px; line-height: 1.6; color: rgba(245,240,232,0.72); max-width: 54ch; margin: 0 auto 28px; }
    .pilot-fine { font-size: 12px; color: var(--muted); margin-top: 22px; }
    .pilot-fine a { color: var(--gold); }

    /* Pilot form */
    .pform { text-align: left; max-width: 560px; margin: 0 auto; display: grid; gap: 14px; }
    .pform-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .pform-field { display: grid; gap: 6px; }
    .pform-field label { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
    .pform-field label .opt { text-transform: none; letter-spacing: 0; opacity: 0.6; }
    .pform-field input, .pform-field select { background: var(--deep); border: 1px solid var(--border); border-radius: 8px; color: var(--white); font-family: 'DM Sans', sans-serif; font-size: 15px; padding: 12px 14px; width: 100%; }
    .pform-field input:focus, .pform-field select:focus { outline: none; border-color: var(--gold); }
    .pform-field input::placeholder { color: rgba(245,240,232,0.3); }
    .pform-btn { width: 100%; border: none; cursor: pointer; margin-top: 4px; }
    .pform-btn[disabled] { opacity: 0.6; cursor: wait; transform: none; }
    .pform-error { color: #e08a7a; font-size: 13px; text-align: center; }
    .pform-success { max-width: 480px; margin: 0 auto; padding: 28px 0 6px; }
    .pform-success h3 { font-size: 26px; margin: 0 0 8px; color: var(--gold); }
    .pform-success p { font-size: 15px; color: rgba(245,240,232,0.72); margin: 0; }

    @media (max-width: 780px) {
      .tier-grid, .inc-grid, .who-row { grid-template-columns: 1fr; }
      .inc-grid { border-radius: 12px; }
      .hero { padding-top: 108px; }
      .strip { gap: 18px; }
      .pform-row { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      .btn-gold { transition: none; }
    }
  </style>

  <script>
    const form = document.getElementById('pilotForm') as HTMLFormElement | null;
    if (form) {
      const errEl = document.getElementById('pfError') as HTMLElement;
      const okEl = document.getElementById('pfSuccess') as HTMLElement;
      const btn = document.getElementById('pfSubmit') as HTMLButtonElement;
      const ref = (new URLSearchParams(window.location.search).get('ref') || '').slice(0, 64);

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errEl.hidden = true;
        if (!form.reportValidity()) return;

        const fd = new FormData(form);
        const plan = String(fd.get('plan') || 'not-sure');
        const payload = {
          name: String(fd.get('name') || '').trim(),
          email: String(fd.get('email') || '').trim(),
          location: String(fd.get('location') || '').trim(),
          business_name: String(fd.get('business_name') || '').trim(),
          phone: String(fd.get('phone') || '').trim() || undefined,
          view: String(fd.get('view') || '').trim() || undefined,
          tier: 'managed-signup',
          message: `Managed signup — plan: ${plan}${ref ? ` · ref: ${ref}` : ''}`,
        };

        btn.disabled = true;
        btn.textContent = 'Sending…';
        try {
          const res = await fetch('/api/host-application', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });
          const data = await res.json().catch(() => ({ success: false }));
          if (res.ok && data.success !== false) {
            form.hidden = true;
            okEl.hidden = false;
          } else {
            throw new Error(data.error || 'submit failed');
          }
        } catch {
          errEl.textContent = 'That didn’t go through — email portofcams@gmail.com and we’ll take it from there.';
          errEl.hidden = false;
          btn.disabled = false;
          btn.textContent = 'Get started';
        }
      });
    }
  </script>
</Layout>
