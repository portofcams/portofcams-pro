---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Host a Camera — Port of Cams"
  description="Partner with Port of Cams. We provide and install professional streaming cameras at your location for free. Get a premium account, daily analytics, and an embeddable live player."
  activeNav="host"
>

  <!-- Hero -->
  <section class="host-hero">
    <div class="host-hero-bg"></div>
    <div class="section-inner" style="position:relative; text-align:center;">
      <div class="host-tag mono">Now Accepting Applications</div>
      <h1 class="display host-title">
        We Install the Camera.<br/>
        <em class="display-italic" style="color: var(--gold)">You Get Premium for Free.</em>
      </h1>
      <p class="host-subtitle">
        Got a great location? We provide and install a professional streaming camera — completely free.
        Every feed runs 100% end-to-end encrypted, direct to our hardened servers.
        You get a free premium account, daily viewer analytics, and an embeddable live player for your website.
      </p>
      <a href="#apply" class="btn-primary">Apply Now</a>
    </div>
  </section>

  <!-- Why Host -->
  <section class="host-why">
    <div class="section-inner">
      <div class="section-label">Why Partner With Us</div>
      <h2 class="display" style="font-size: clamp(36px, 4vw, 56px); margin-bottom: 60px;">
        Zero Effort. <em class="display-italic" style="color: var(--gold)">Maximum Exposure.</em>
      </h2>

      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          </div>
          <h3>We Provide the Hardware</h3>
          <p>We supply and ship a professional-grade streaming camera to your location at no cost. We walk you through the one-time plug-in. That's it — you're done.</p>
        </div>

        <div class="why-card">
          <div class="why-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <h3>Real Audience</h3>
          <p>Tap into our growing audience of Hawaii locals, travelers, researchers, and remote viewers hungry for live island content.</p>
        </div>

        <div class="why-card">
          <div class="why-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
          </div>
          <h3>Free Premium Account</h3>
          <p>Every camera host gets a complimentary premium account ($9.99/month value) with full HD access to the entire Port of Cams network, plus daily viewer analytics.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Security -->
  <section class="host-security">
    <div class="section-inner">
      <div class="section-label">Built From the Ground Up</div>
      <h2 class="display" style="font-size: clamp(36px, 4vw, 56px); margin-bottom: 16px;">
        Security We Spent Months <em class="display-italic" style="color: var(--gold)">Engineering</em>
      </h2>
      <p style="color: var(--muted); font-size: 15px; margin-bottom: 60px; max-width: 600px; line-height: 1.8;">
        Before we streamed a single frame, we spent months hardening the infrastructure.
        Every decision — from how the camera connects to how viewers receive segments — was designed with security first.
      </p>

      <div class="security-grid">
        <div class="security-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <div>
            <h4>100% Encrypted Feed, End to End</h4>
            <p>Every byte your camera transmits travels over TLS-encrypted RTMP — from the moment it leaves your location to the moment it lands on our servers.</p>
          </div>
        </div>

        <div class="security-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          <div>
            <h4>Hardened Private Infrastructure</h4>
            <p>Our streaming servers run on locked-down private endpoints — no public RTMP exposure, no shared ingress. Months of penetration testing and DDoS mitigation are baked in.</p>
          </div>
        </div>

        <div class="security-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path></svg>
          <div>
            <h4>Unique Stream Keys Per Camera</h4>
            <p>Each camera gets a cryptographically unique stream key. Keys are rotated on demand. Even if one were compromised, zero other feeds are affected.</p>
          </div>
        </div>

        <div class="security-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0 1 12 2.944a11.955 11.955 0 0 1-8.618 3.04A12.02 12.02 0 0 0 3 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          <div>
            <h4>Authenticated HLS Delivery</h4>
            <p>Viewers receive time-limited, signed segment URLs. Nobody can hotlink or leech your stream. Premium feeds add an additional token layer.</p>
          </div>
        </div>
      </div>

      <!-- Trust bar -->
      <div class="trust-bar">
        <div><span class="trust-val">TLS 1.3</span><span class="trust-label mono">Encrypted Transport</span></div>
        <div><span class="trust-val">Signed</span><span class="trust-label mono">HLS Segments</span></div>
        <div><span class="trust-val">Private</span><span class="trust-label mono">RTMP Endpoints</span></div>
        <div><span class="trust-val">Zero</span><span class="trust-label mono">Public Exposure</span></div>
      </div>
    </div>
  </section>

  <!-- Tiers -->
  <section class="host-tiers">
    <div class="section-inner">
      <div class="section-label">What You Get</div>
      <h2 class="display" style="font-size: clamp(36px, 4vw, 56px); margin-bottom: 60px;">
        Free vs. <em class="display-italic" style="color: var(--gold)">Premium</em> Hosting
      </h2>

      <div class="tier-grid">
        <!-- Free -->
        <div class="tier-card">
          <div class="tier-header">
            <span class="tier-label mono">Free</span>
            <div class="tier-price display">$0 <span class="tier-period">/ month</span></div>
            <p class="tier-desc">Get listed and start streaming. No credit card.</p>
          </div>
          <ul class="tier-features">
            <li><span class="check">&#10003;</span> Listed on the public cameras page</li>
            <li><span class="check">&#10003;</span> Unlimited live streaming hours</li>
            <li><span class="check">&#10003;</span> Basic viewer count stats</li>
            <li><span class="check">&#10003;</span> Standard HLS stream delivery</li>
            <li><span class="check">&#10003;</span> Community exposure &amp; discovery</li>
            <li><span class="check">&#10003;</span> Port of Cams branding on your feed</li>
          </ul>
          <a href="#apply" class="btn-secondary tier-btn">Apply Free</a>
        </div>

        <!-- Premium -->
        <div class="tier-card featured">
          <div class="tier-badge mono">Premium</div>
          <div class="tier-header">
            <span class="tier-label mono" style="color: var(--gold);">Premium Host</span>
            <div class="tier-price display">Free <span class="tier-period">($9.99/mo value)</span></div>
            <p class="tier-desc">Complimentary premium account for every camera host.</p>
          </div>
          <ul class="tier-features">
            <li><span class="check gold">&#10003;</span> Everything in Free</li>
            <li><span class="check gold">&#10003;</span> Free premium account ($9.99/month value)</li>
            <li><span class="check gold">&#10003;</span> We provide &amp; install all camera equipment</li>
            <li><span class="check gold">&#10003;</span> Featured homepage placement &amp; player</li>
            <li><span class="check gold">&#10003;</span> 48-Hour DVR — viewers rewind up to 2 days</li>
            <li><span class="check gold">&#10003;</span> Daily viewer analytics dashboard</li>
            <li><span class="check gold">&#10003;</span> Embeddable live player for your own website</li>
            <li><span class="check gold">&#10003;</span> Priority stream health monitoring</li>
            <li><span class="check gold">&#10003;</span> Dedicated support channel</li>
          </ul>
          <a href="#apply" class="btn-primary tier-btn" data-prefill-tier="premium">Apply for Premium</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sponsorship -->
  <section class="host-sponsorship">
    <div class="section-inner">
      <div class="sponsor-card">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg>
        <div>
          <h3>Sponsorship Opportunities</h3>
          <p>Premium camera operators can partner with local businesses, tourism boards, and brands for sponsored feeds.
          Your camera's live view becomes a branded experience. We facilitate introductions and handle ad placement logistics.</p>
        </div>
        <a href="#apply" class="btn-secondary" style="flex-shrink:0; white-space:nowrap;" data-prefill-tier="sponsorship" data-prefill-adv="yes">Learn More</a>
      </div>
    </div>
  </section>

  <!-- Application Form -->
  <section class="host-apply" id="apply">
    <div class="section-inner">
      <div class="section-label">Get Started</div>
      <h2 class="display" style="font-size: clamp(36px, 4vw, 56px); margin-bottom: 16px;">
        Apply for a Camera <em class="display-italic" style="color: var(--gold)">Installation</em>
      </h2>
      <p style="color: rgba(245,240,232,0.65); font-size: 16px; margin-bottom: 48px; max-width: 520px; line-height: 1.7;">
        Four quick steps. We review every application, then ship and walk you through the hardware — you'll hear back within 48 hours.
      </p>

      <div class="form-wrapper">
        <!-- Progress -->
        <div class="wiz-progress" id="wizProgress">
          <div class="wiz-steps mono">
            <span class="wiz-stepname is-active" data-for="1"><i>1</i> You &amp; the spot</span>
            <span class="wiz-stepname" data-for="2"><i>2</i> The view</span>
            <span class="wiz-stepname" data-for="3"><i>3</i> Setup</span>
            <span class="wiz-stepname" data-for="4"><i>4</i> Plan</span>
          </div>
          <div class="wiz-bar"><div class="wiz-bar-fill" id="wizBarFill"></div></div>
        </div>

        <form id="hostForm" novalidate>
          <!-- STEP 1 — You & the spot -->
          <fieldset class="wiz-step is-active" data-step="1">
            <div class="form-row">
              <div class="form-group">
                <label for="hfName" class="form-label mono">Your name *</label>
                <input id="hfName" required type="text" autocomplete="name" placeholder="Kai Makoa" class="form-input" />
              </div>
              <div class="form-group">
                <label for="hfEmail" class="form-label mono">Email *</label>
                <input id="hfEmail" required type="email" autocomplete="email" placeholder="you@example.com" class="form-input" />
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="hfPhone" class="form-label mono">Phone <span class="opt">(optional)</span></label>
                <input id="hfPhone" type="tel" autocomplete="tel" placeholder="(808) 555-0142" class="form-input" />
              </div>
              <div class="form-group">
                <label for="hfLocation" class="form-label mono">Location *</label>
                <input id="hfLocation" required type="text" placeholder="Venice, CA" class="form-input" />
              </div>
            </div>
            <div class="form-group">
              <label class="form-label mono">Your relationship to the property *</label>
              <div class="choice-group" data-name="property">
                <button type="button" class="choice" data-value="own">I own it</button>
                <button type="button" class="choice" data-value="manage">I manage / lease it</button>
                <button type="button" class="choice" data-value="permission">I have permission to install</button>
                <button type="button" class="choice" data-value="need-permission">I'd need to get permission</button>
              </div>
            </div>
          </fieldset>

          <!-- STEP 2 — The view -->
          <fieldset class="wiz-step" data-step="2">
            <div class="form-group">
              <label class="form-label mono">Photo of the view *</label>
              <p class="field-help">A quick snap from where the camera would sit. This is the single biggest factor in how fast we say yes.</p>
              <label class="photo-drop" id="photoDrop" for="hfPhoto">
                <input id="hfPhoto" type="file" accept="image/*" hidden />
                <div class="photo-empty" id="photoEmpty">
                  <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                  <span class="photo-title">Tap to add a photo</span>
                  <span class="photo-sub">or drag an image here &middot; JPG, PNG, HEIC</span>
                </div>
                <div class="photo-preview" id="photoPreview" hidden>
                  <img id="photoImg" alt="View preview" />
                  <div class="photo-meta">
                    <span id="photoName" class="mono"></span>
                    <button type="button" class="photo-remove" id="photoRemove">Remove</button>
                  </div>
                </div>
              </label>
              <label class="photo-later">
                <input type="checkbox" id="photoLater" />
                <span>I don't have a photo right now &mdash; I'll email one later</span>
              </label>
            </div>
            <div class="form-group">
              <label class="form-label mono">What does the camera see? <span class="opt">(pick any)</span></label>
              <div class="tag-group" data-name="viewTags">
                <button type="button" class="tag" data-value="Beach">Beach</button>
                <button type="button" class="tag" data-value="Surf break">Surf break</button>
                <button type="button" class="tag" data-value="Harbor / marina">Harbor / marina</button>
                <button type="button" class="tag" data-value="Mountains">Mountains</button>
                <button type="button" class="tag" data-value="Volcano">Volcano</button>
                <button type="button" class="tag" data-value="Waterfall">Waterfall</button>
                <button type="button" class="tag" data-value="City / skyline">City / skyline</button>
                <button type="button" class="tag" data-value="Sunset / horizon">Sunset / horizon</button>
                <button type="button" class="tag" data-value="Wildlife">Wildlife</button>
                <button type="button" class="tag" data-value="Traffic / street">Traffic / street</button>
                <button type="button" class="tag" data-value="Resort / pool">Resort / pool</button>
                <button type="button" class="tag" data-value="Other">Other</button>
              </div>
            </div>
            <div class="form-group">
              <label for="hfView" class="form-label mono">Describe the view <span class="opt">(optional)</span></label>
              <input id="hfView" type="text" placeholder="Beachfront on the Venice Boardwalk, facing the sunset" class="form-input" />
            </div>
          </fieldset>

          <!-- STEP 3 — Setup -->
          <fieldset class="wiz-step" data-step="3">
            <p class="field-help" style="margin-top:0;">This tells us what to ship and how to get you live fast. Not sure? Just give your best guess.</p>
            <div class="form-group">
              <label class="form-label mono">Internet at the location *</label>
              <div class="choice-group" data-name="internet">
                <button type="button" class="choice" data-value="wifi">Wi-Fi</button>
                <button type="button" class="choice" data-value="ethernet">Wired ethernet</button>
                <button type="button" class="choice" data-value="cellular">Cellular only</button>
                <button type="button" class="choice" data-value="none">None yet</button>
                <button type="button" class="choice" data-value="unsure">Not sure</button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label mono">Power outlet near the mount point? *</label>
              <div class="choice-group" data-name="power">
                <button type="button" class="choice" data-value="yes">Yes</button>
                <button type="button" class="choice" data-value="no">No</button>
                <button type="button" class="choice" data-value="unsure">Not sure</button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label mono">Where would the camera mount? <span class="opt">(optional)</span></label>
              <div class="choice-group" data-name="mount">
                <button type="button" class="choice" data-value="window">Inside, through a window</button>
                <button type="button" class="choice" data-value="wall">Exterior wall</button>
                <button type="button" class="choice" data-value="roof-pole">Roof or pole</button>
                <button type="button" class="choice" data-value="railing">Railing or deck</button>
                <button type="button" class="choice" data-value="unsure">Not sure</button>
              </div>
            </div>
          </fieldset>

          <!-- STEP 4 — Plan & advertising -->
          <fieldset class="wiz-step" data-step="4">
            <div class="form-group">
              <label class="form-label mono">Which are you interested in?</label>
              <div class="choice-group" data-name="tier">
                <button type="button" class="choice is-active" data-value="free" aria-pressed="true">Free listing</button>
                <button type="button" class="choice" data-value="premium">Premium host</button>
                <button type="button" class="choice" data-value="sponsorship">Sponsorship</button>
              </div>
            </div>
            <div class="form-group">
              <label class="form-label mono">Open to advertising or a sponsored placement on your feed?</label>
              <p class="field-help">Premium feeds can carry one tasteful local sponsor. You always approve who appears.</p>
              <div class="choice-group" data-name="advertising">
                <button type="button" class="choice" data-value="yes">Yes, I'm interested</button>
                <button type="button" class="choice" data-value="maybe">Maybe &mdash; tell me more</button>
                <button type="button" class="choice" data-value="no">No thanks</button>
              </div>
            </div>
            <div class="adv-fields" id="advFields" hidden>
              <div class="form-row">
                <div class="form-group">
                  <label for="hfBizName" class="form-label mono">Business or brand <span class="opt">(optional)</span></label>
                  <input id="hfBizName" type="text" placeholder="Venice Beach Cafe" class="form-input" />
                </div>
                <div class="form-group">
                  <label for="hfBizUrl" class="form-label mono">Website or social <span class="opt">(optional)</span></label>
                  <input id="hfBizUrl" type="text" inputmode="url" placeholder="instagram.com/yourspot" class="form-input" />
                </div>
              </div>
            </div>
            <div class="form-group">
              <label for="hfMessage" class="form-label mono">Anything else? <span class="opt">(optional)</span></label>
              <textarea id="hfMessage" rows="3" placeholder="Camera ideas, best time to reach you, questions..." class="form-input form-textarea"></textarea>
            </div>
          </fieldset>

          <!-- Inline per-step error -->
          <div id="hfStepError" class="form-error" style="display:none;"></div>

          <!-- Navigation -->
          <div class="wiz-nav">
            <button type="button" class="btn-secondary wiz-back" id="wizBack" hidden>Back</button>
            <button type="button" class="btn-primary wiz-advance" id="wizNext">Continue</button>
            <button type="submit" class="btn-primary wiz-advance" id="hfSubmit" hidden>Submit application</button>
          </div>
        </form>

        <!-- Success message -->
        <div id="hfSuccess" class="form-success" style="display:none;">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          <h3 class="display" style="font-size: 28px; margin-top: 16px;">Application received!</h3>
          <p style="color: var(--muted); font-size: 15px; line-height: 1.7; margin-top: 8px;">
            We'll review your view and be in touch within 48 hours.<br/>
            Confirmation headed to <span id="hfConfirmEmail" style="color: var(--gold);"></span>
          </p>
        </div>

        <!-- Fatal error message -->
        <div id="hfError" class="form-error" style="display:none;"></div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .host-hero {
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-top: 80px;
  }

  .host-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 50% 30%, rgba(201,168,76,0.08) 0%, transparent 70%),
      linear-gradient(180deg, #080808 0%, #0a0905 100%);
  }

  .host-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 1px;
    margin-bottom: 32px;
  }

  .host-title {
    font-size: clamp(40px, 6vw, 80px);
    max-width: 800px;
    margin: 0 auto 28px;
  }

  .host-subtitle {
    font-size: 16px;
    color: var(--muted);
    max-width: 560px;
    line-height: 1.8;
    margin: 0 auto 40px;
  }

  /* Why section */
  .host-why {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .why-card {
    background: var(--deep);
    padding: 40px 32px;
  }

  .why-icon { margin-bottom: 20px; }

  .why-card h3 {
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 12px;
  }

  .why-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
  }

  /* Security */
  .host-security {
    border-top: 1px solid var(--border);
  }

  .security-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-bottom: 40px;
  }

  .security-card {
    background: var(--surface);
    padding: 32px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .security-card svg { flex-shrink: 0; margin-top: 2px; }

  .security-card h4 {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .security-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.8;
  }

  .trust-bar {
    display: flex;
    justify-content: center;
    gap: 48px;
    padding: 32px;
    border: 1px solid var(--border);
    background: var(--surface);
    text-align: center;
  }

  .trust-bar > div {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .trust-val {
    font-size: 18px;
    font-weight: 600;
    color: var(--gold);
  }

  .trust-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* Tiers */
  .host-tiers {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .tier-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    max-width: 800px;
  }

  .tier-card {
    background: var(--surface);
    padding: 48px 40px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .tier-card.featured {
    background: var(--deep);
    border: 1px solid var(--gold);
    margin: -1px;
    z-index: 1;
  }

  .tier-badge {
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--black);
    background: var(--gold);
    padding: 4px 12px;
    display: inline-block;
    margin-bottom: 16px;
    width: fit-content;
  }

  .tier-label {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .tier-price {
    font-size: 48px;
    font-weight: 300;
    line-height: 1;
    margin: 8px 0 4px;
  }

  .tier-period {
    font-size: 14px;
    font-weight: 300;
    color: var(--muted);
    font-family: 'DM Sans', sans-serif;
  }

  .tier-desc {
    font-size: 13px;
    color: var(--muted);
    margin-top: 8px;
    margin-bottom: 24px;
  }

  .tier-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 32px;
    flex: 1;
  }

  .tier-features li {
    font-size: 13px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tier-features .check {
    color: rgba(245,240,232,0.2);
    flex-shrink: 0;
    width: 16px;
    text-align: center;
  }

  .tier-features .check.gold { color: var(--gold); }

  .tier-btn {
    display: block;
    text-align: center;
    font-size: 12px;
    margin-top: auto;
  }

  /* Sponsorship */
  .host-sponsorship {
    border-top: 1px solid var(--border);
  }

  .sponsor-card {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 40px;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .sponsor-card h3 {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .sponsor-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
  }

  /* Form */
  .host-apply {
    border-top: 1px solid var(--border);
    background: var(--deep);
  }

  .form-wrapper {
    max-width: 600px;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 48px 40px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }

  .form-group { margin-bottom: 16px; }
  .form-row .form-group { margin-bottom: 0; }

  .form-label {
    display: block;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.75);
    margin-bottom: 10px;
    font-weight: 500;
  }

  .form-input {
    width: 100%;
    padding: 14px 16px;
    background: #0f0f0f;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2px;
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 400;
    outline: none;
    transition: border-color 0.3s;
  }

  .form-input:focus { border-color: var(--gold); }

  .form-input::placeholder { color: rgba(245,240,232,0.32); }

  select.form-input {
    appearance: none;
    cursor: pointer;
  }

  .form-textarea { resize: none; }

  .form-submit {
    width: 100%;
    margin-top: 8px;
    text-align: center;
  }

  /* Success message */
  .form-success {
    text-align: center;
    padding: 48px 24px;
    border: 1px solid var(--gold);
    border-radius: 2px;
    background: rgba(201,168,76,0.04);
  }

  /* Error message */
  .form-error {
    margin-top: 16px;
    padding: 16px 20px;
    border: 1px solid rgba(239,68,68,0.3);
    background: rgba(239,68,68,0.06);
    color: #ef4444;
    font-size: 14px;
    border-radius: 2px;
    text-align: center;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .host-hero { min-height: 60vh; }
    .why-grid { grid-template-columns: 1fr; }
    .security-grid { grid-template-columns: 1fr; }
    .tier-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
    .sponsor-card { flex-direction: column; text-align: center; }
    .trust-bar { flex-wrap: wrap; gap: 24px; }
    .form-wrapper { padding: 32px 24px; }
  }

  /* ── Wizard ─────────────────────────────────────── */
  /* The .btn-* and .photo-* classes set their own display, which would
     override the UA [hidden] rule — force hidden to win inside the form. */
  .host-apply [hidden] { display: none !important; }

  .opt { color: var(--muted); text-transform: none; letter-spacing: 0; font-weight: 400; }

  .field-help {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin: -2px 0 14px;
  }

  /* Progress */
  .wiz-progress { margin-bottom: 32px; }

  .wiz-steps {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .wiz-stepname {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(245,240,232,0.32);
    transition: color 0.3s;
  }

  .wiz-stepname i {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 19px;
    height: 19px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.18);
    font-style: normal;
    font-size: 10px;
    transition: all 0.3s;
  }

  .wiz-stepname.is-active { color: var(--gold); }
  .wiz-stepname.is-active i { border-color: var(--gold); color: var(--gold); }
  .wiz-stepname.is-done { color: rgba(245,240,232,0.55); }
  .wiz-stepname.is-done i {
    border-color: var(--gold);
    background: var(--gold);
    color: var(--black);
  }

  .wiz-bar {
    height: 3px;
    background: rgba(255,255,255,0.08);
    border-radius: 3px;
    overflow: hidden;
  }

  .wiz-bar-fill {
    height: 100%;
    width: 25%;
    background: var(--gold);
    border-radius: 3px;
    transition: width 0.4s cubic-bezier(0.16,1,0.3,1);
  }

  /* Steps */
  .wiz-step {
    border: 0;
    padding: 0;
    margin: 0;
    display: none;
    animation: wizFade 0.35s ease;
  }
  .wiz-step.is-active { display: block; }

  @keyframes wizFade {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Choice + tag chips */
  .choice-group { display: flex; flex-wrap: wrap; gap: 10px; }

  .choice, .tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    color: rgba(245,240,232,0.7);
    background: #0f0f0f;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2px;
    padding: 11px 16px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    text-align: left;
  }

  .choice:hover, .tag:hover { border-color: rgba(201,168,76,0.5); color: var(--white); }

  .choice.is-active, .tag.is-active {
    border-color: var(--gold);
    background: rgba(201,168,76,0.1);
    color: var(--gold);
  }

  .tag-group { display: flex; flex-wrap: wrap; gap: 8px; }
  .tag { padding: 9px 14px; border-radius: 100px; font-size: 12px; }

  /* Photo upload */
  .photo-drop {
    display: block;
    border: 1px dashed rgba(201,168,76,0.4);
    border-radius: 3px;
    background: rgba(201,168,76,0.03);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    overflow: hidden;
  }
  .photo-drop:hover, .photo-drop.is-drag {
    border-color: var(--gold);
    background: rgba(201,168,76,0.07);
  }

  .photo-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 40px 24px;
    text-align: center;
  }
  .photo-title { font-size: 15px; color: var(--white); }
  .photo-sub { font-size: 12px; color: var(--muted); }

  .photo-preview { padding: 12px; }
  .photo-preview img {
    width: 100%;
    max-height: 280px;
    object-fit: cover;
    border-radius: 2px;
    display: block;
    background: #000;
  }
  .photo-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 10px;
  }
  #photoName {
    font-size: 12px;
    color: var(--muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .photo-remove {
    background: none;
    border: 0;
    color: var(--gold);
    font-size: 12px;
    cursor: pointer;
    padding: 4px 6px;
    flex-shrink: 0;
    font-family: 'DM Mono', monospace;
  }
  .photo-remove:hover { color: var(--gold-light); }

  .photo-later {
    display: flex;
    align-items: center;
    gap: 9px;
    margin-top: 12px;
    font-size: 13px;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
  }
  .photo-later input { accent-color: var(--gold); width: 15px; height: 15px; cursor: pointer; flex-shrink: 0; }
  .photo-later:hover { color: rgba(245,240,232,0.7); }

  /* Navigation */
  .wiz-nav {
    display: flex;
    gap: 12px;
    margin-top: 28px;
  }
  .wiz-advance { flex: 1; text-align: center; }
  .wiz-back { flex-shrink: 0; }

  .host-apply .form-error { animation: wizFade 0.25s ease; }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('hostForm');
    if (!form) return;

    var TOTAL_STEPS = 4;
    var current = 1;
    var photoDataUrl = null;

    var $ = function (id) { return document.getElementById(id); };
    var qsa = function (sel, root) { return Array.prototype.slice.call((root || document).querySelectorAll(sel)); };

    var EMAIL_RE = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;

    // \u2500\u2500 Choice groups (single-select) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    qsa('.choice-group').forEach(function (group) {
      group.addEventListener('click', function (e) {
        var btn = e.target.closest('.choice');
        if (!btn) return;
        var active = btn.classList.contains('is-active');
        qsa('.choice', group).forEach(function (b) {
          b.classList.remove('is-active');
          b.setAttribute('aria-pressed', 'false');
        });
        if (!active) {
          btn.classList.add('is-active');
          btn.setAttribute('aria-pressed', 'true');
        }
        if (group.getAttribute('data-name') === 'advertising') syncAdvFields();
        clearError();
      });
    });

    // \u2500\u2500 Tag groups (multi-select) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    qsa('.tag-group').forEach(function (group) {
      group.addEventListener('click', function (e) {
        var btn = e.target.closest('.tag');
        if (!btn) return;
        btn.classList.toggle('is-active');
        btn.setAttribute('aria-pressed', btn.classList.contains('is-active') ? 'true' : 'false');
      });
    });

    function getChoice(name) {
      var el = document.querySelector('.choice-group[data-name="' + name + '"] .choice.is-active');
      return el ? el.getAttribute('data-value') : '';
    }
    function getTags(name) {
      return qsa('.tag-group[data-name="' + name + '"] .tag.is-active').map(function (b) {
        return b.getAttribute('data-value');
      });
    }

    function syncAdvFields() {
      var v = getChoice('advertising');
      $('advFields').hidden = !(v === 'yes' || v === 'maybe');
    }

    // \u2500\u2500 Photo upload + client-side compression \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    var input = $('hfPhoto');
    var drop = $('photoDrop');

    function compress(file) {
      return new Promise(function (resolve, reject) {
        var reader = new FileReader();
        reader.onerror = function () { reject(new Error('read')); };
        reader.onload = function (ev) {
          var img = new Image();
          img.onerror = function () {
            // Can't decode (e.g. some HEIC) \u2014 fall back to the raw data URL if small enough.
            if (typeof ev.target.result === 'string' && ev.target.result.length < 7000000) {
              resolve(ev.target.result);
            } else {
              reject(new Error('decode'));
            }
          };
          img.onload = function () {
            var maxDim = 1600;
            var scale = Math.min(1, maxDim / Math.max(img.width, img.height));
            var w = Math.round(img.width * scale);
            var h = Math.round(img.height * scale);
            var canvas = document.createElement('canvas');
            canvas.width = w; canvas.height = h;
            canvas.getContext('2d').drawImage(img, 0, 0, w, h);
            try {
              resolve(canvas.toDataURL('image/jpeg', 0.82));
            } catch (err) { reject(err); }
          };
          img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
      });
    }

    function handleFile(file) {
      if (!file || !/^image\//.test(file.type) && !/\.(jpe?g|png|heic|heif|webp)$/i.test(file.name)) {
        showError('Please choose an image file (JPG, PNG, or HEIC).');
        return;
      }
      drop.classList.remove('is-drag');
      compress(file).then(function (dataUrl) {
        photoDataUrl = dataUrl;
        $('photoImg').src = dataUrl;
        $('photoName').textContent = file.name;
        $('photoEmpty').hidden = true;
        $('photoPreview').hidden = false;
        clearError();
      }).catch(function () {
        showError('Could not read that image. Try a JPG or PNG instead.');
      });
    }

    input.addEventListener('change', function () {
      if (input.files && input.files[0]) handleFile(input.files[0]);
    });

    $('photoRemove').addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      photoDataUrl = null;
      input.value = '';
      $('photoImg').removeAttribute('src');
      $('photoPreview').hidden = true;
      $('photoEmpty').hidden = false;
    });

    $('photoLater').addEventListener('change', function () { clearError(); });

    ['dragover', 'dragenter'].forEach(function (evt) {
      drop.addEventListener(evt, function (e) { e.preventDefault(); drop.classList.add('is-drag'); });
    });
    ['dragleave', 'dragend'].forEach(function (evt) {
      drop.addEventListener(evt, function () { drop.classList.remove('is-drag'); });
    });
    drop.addEventListener('drop', function (e) {
      e.preventDefault();
      if (e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
    });

    // \u2500\u2500 Step navigation \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    function showError(msg) {
      var el = $('hfStepError');
      el.textContent = msg;
      el.style.display = 'block';
    }
    function clearError() { $('hfStepError').style.display = 'none'; }

    function validateStep(n) {
      if (n === 1) {
        if (!$('hfName').value.trim()) return 'Please add your name.';
        if (!EMAIL_RE.test($('hfEmail').value.trim())) return 'Please add a valid email.';
        if (!$('hfLocation').value.trim()) return 'Where is the spot? Add a location.';
        if (!getChoice('property')) return 'Pick your relationship to the property.';
      } else if (n === 2) {
        if (!photoDataUrl && !$('photoLater').checked) return 'Add a photo of the view \u2014 or check "I\'ll email one later" below.';
      } else if (n === 3) {
        if (!getChoice('internet')) return "Let us know the spot's internet.";
        if (!getChoice('power')) return 'Is there power near the mount point?';
      }
      return null;
    }

    function render() {
      qsa('.wiz-step').forEach(function (s) {
        s.classList.toggle('is-active', Number(s.getAttribute('data-step')) === current);
      });
      qsa('.wiz-stepname').forEach(function (s) {
        var n = Number(s.getAttribute('data-for'));
        s.classList.toggle('is-active', n === current);
        s.classList.toggle('is-done', n < current);
      });
      $('wizBarFill').style.width = (current / TOTAL_STEPS * 100) + '%';
      $('wizBack').hidden = current === 1;
      $('wizNext').hidden = current === TOTAL_STEPS;
      $('hfSubmit').hidden = current !== TOTAL_STEPS;
      clearError();
    }

    function goTo(n) {
      current = Math.max(1, Math.min(TOTAL_STEPS, n));
      render();
      var top = document.getElementById('apply');
      if (top) top.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    $('wizNext').addEventListener('click', function () {
      var err = validateStep(current);
      if (err) { showError(err); return; }
      goTo(current + 1);
    });
    $('wizBack').addEventListener('click', function () { goTo(current - 1); });

    // \u2500\u2500 Prefill from CTA buttons (Premium / Sponsorship) \u2500
    qsa('a[data-prefill-tier]').forEach(function (a) {
      a.addEventListener('click', function () {
        var tier = a.getAttribute('data-prefill-tier');
        var btn = document.querySelector('.choice-group[data-name="tier"] .choice[data-value="' + tier + '"]');
        if (btn) {
          qsa('.choice-group[data-name="tier"] .choice').forEach(function (b) { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
          btn.classList.add('is-active'); btn.setAttribute('aria-pressed', 'true');
        }
        if (a.getAttribute('data-prefill-adv')) {
          var adv = document.querySelector('.choice-group[data-name="advertising"] .choice[data-value="' + a.getAttribute('data-prefill-adv') + '"]');
          if (adv) {
            qsa('.choice-group[data-name="advertising"] .choice').forEach(function (b) { b.classList.remove('is-active'); b.setAttribute('aria-pressed', 'false'); });
            adv.classList.add('is-active'); adv.setAttribute('aria-pressed', 'true');
            syncAdvFields();
          }
        }
      });
    });

    // \u2500\u2500 Submit \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      // Re-validate every gated step in case of skips.
      for (var s = 1; s <= TOTAL_STEPS; s++) {
        var err = validateStep(s);
        if (err) { goTo(s); showError(err); return; }
      }

      var btn = $('hfSubmit');
      btn.disabled = true;
      btn.textContent = 'Sending\u2026';

      var payload = {
        name: $('hfName').value.trim(),
        email: $('hfEmail').value.trim(),
        phone: $('hfPhone').value.trim(),
        location: $('hfLocation').value.trim(),
        property_relationship: getChoice('property'),
        view_photo: photoDataUrl || '',
        photo_later: $('photoLater').checked,
        view_tags: getTags('viewTags'),
        view: $('hfView').value.trim(),
        internet: getChoice('internet'),
        power: getChoice('power'),
        mount: getChoice('mount'),
        tier: getChoice('tier') || 'free',
        advertising: getChoice('advertising'),
        business_name: $('hfBizName').value.trim(),
        business_url: $('hfBizUrl').value.trim(),
        message: $('hfMessage').value.trim()
      };

      fetch('/api/host-application', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (res) {
          if (res.ok) {
            form.style.display = 'none';
            $('wizProgress').style.display = 'none';
            $('hfSuccess').style.display = 'block';
            var ce = $('hfConfirmEmail');
            if (ce) ce.textContent = payload.email;
          } else {
            throw new Error('Server error');
          }
        })
        .catch(function () {
          var errEl = $('hfError');
          errEl.style.display = 'block';
          errEl.textContent = 'Something went wrong. Email us directly at Portofcams@gmail.com';
          btn.disabled = false;
          btn.textContent = 'Submit application';
        });
    });

    render();
  })();
</script>
