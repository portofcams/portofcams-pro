---
import Layout from '../../../layouts/Layout.astro';
import HLSPlayer from '../../../components/HLSPlayer.astro';

// Pitch-aid demo pages for the Managed Marketing Cam tier — one per venue archetype.
// noindex: these are walk-in / warm-email leave-behinds, not SEO surface.
// Every asset shown is ours and real: the live Lewers St feed + clips cut by the
// same pipeline that would serve the venue. No client names — landmarks only.

export function getStaticPaths() {
  return [
    { params: { archetype: 'hotel' } },
    { params: { archetype: 'marina' } },
    { params: { archetype: 'surf-shop' } },
    { params: { archetype: 'dive' } },
    { params: { archetype: 'club' } },
    { params: { archetype: 'venue' } },
    { params: { archetype: 'rental' } },
    { params: { archetype: 'fb' } },
  ];
}

const { archetype } = Astro.params;

const CONTENT: Record<string, {
  eyebrow: string; h1: [string, string]; lede: string;
  points: [string, string][]; caption: string;
}> = {
  'hotel': {
    eyebrow: 'Prepared for Waikīkī hotels & resorts',
    h1: ['Your beachfront,', 'live on your booking page.'],
    lede: 'People book the ocean they can see. A live view of your stretch of sand — on your own site, under your own brand — is the booking-page hero that never needs a photographer, a reshoot, or a sunny day scheduled in advance.',
    points: [
      ['The view sells the room', 'Guests deciding between two properties pick the one whose ocean they just watched. Your view becomes a reason to book direct instead of through an OTA.'],
      ['Fresh social, zero effort', 'Every month we cut branded sunset and golden-hour clips from your feed — ready for your Instagram, no content team required.'],
      ['Handled end to end', 'We mount it, aim it, host it, watch it, and swap it if the salt wins. Your staff never touches a cable.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī — two blocks from the sand. Your beachfront drops into your website exactly like this, co-branded.',
  },
  'marina': {
    eyebrow: 'Prepared for Oʻahu marinas & harbors',
    h1: ['Slip-holders check the harbor', 'before they drive down.'],
    lede: 'A live harbor cam is the page your slip-holders open every morning — wind on the water, space at the fuel dock, whether the fleet is in. That daily habit keeps your marina top-of-mind, and puts transient moorage in front of every visiting boater who finds the feed.',
    points: [
      ['The daily-check habit', 'Conditions, chop, and traffic at a glance. Your website becomes the first tab of every boat owner’s morning.'],
      ['Transient moorage marketing', 'Visiting boaters watch the harbor before they commit. A live view answers the question every one of them has: what does it actually look like in there?'],
      ['Office sees what members see', 'The same feed works as a casual eye on the docks after hours — not a security system, but a public view that never blinks.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your fairway, fuel dock, or mooring field streams exactly like this, co-branded on your own site.',
  },
  'surf-shop': {
    eyebrow: 'Prepared for Oʻahu surf & dive shops',
    h1: ['Dawn patrol checks your break —', 'on your site, not someone else’s.'],
    lede: 'Every surfer on this island checks a cam before they drive. Right now they check someone else’s. A live view of the break out front makes your shop the morning ritual — and the person watching your wave is one scroll from your board rack, your rentals, and your lesson calendar.',
    points: [
      ['Become the morning ritual', 'The break check is the highest-frequency visit in surf retail. Own it and you own the first screen of the day.'],
      ['Traffic that converts', 'The cam page cross-sells rentals, lessons, and wax — to exactly the person about to paddle out in front of your door.'],
      ['Clips your followers share', 'When it’s firing, we cut the timelapse. Your shop’s name rides every share of that swell.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your break streams exactly like this — co-branded, on your own site, working before sunrise.',
  },
  'dive': {
    eyebrow: 'Prepared for Oʻahu dive & charter operations',
    h1: ['Divers check conditions', 'before they commit to the drive.'],
    lede: 'Every diver and every student wants the same thing before a boat day: to see the water. A live view of your harbor or your departure dock answers the morning question — and the person watching it is one scroll from your charter calendar, your certification courses, and your rental counter.',
    points: [
      ['The boat-day check', 'Chop, wind on the water, what the fleet is doing — your customers see it live on your site instead of texting the shop at 6am.'],
      ['Conditions build trust', 'Showing the real water, live, says more than any brochure photo. Confident divers book; nervous students show up already reassured.'],
      ['Clips of every departure', 'We cut monthly branded clips from your feed — boats heading out at golden hour is exactly the content your Instagram wants.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your dock, your harbor, or your reef-front streams exactly like this — co-branded, on your own site.',
  },
  'club': {
    eyebrow: 'Prepared for Oʻahu ocean & yacht clubs',
    h1: ['Your members check the water', 'before they leave the house.'],
    lede: 'A club lives on its stretch of water. A live view of it — on the club\'s own site, behind nothing — is the page members open with their coffee: what the break is doing, how the fairway looks, whether the racing will be good. It keeps the club in every member\'s morning, wherever in the world they are.',
    points: [
      ['The morning ritual', 'Conditions at a glance before the drive — paddlers, sailors, and swimmers check the water first. Your site becomes the first tab of the day.'],
      ['Race days, witnessed', 'Regattas and races stream live — family on the beach lawn, mainland members, and reciprocal-club friends all watching your water.'],
      ['Clips for the newsletter', 'Every month we cut branded timelapses from your feed — golden-hour water, canoes going out — ready for the club newsletter and social pages.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your club\'s water streams exactly like this — co-branded, on your own site. Public ocean view only: the camera sees the water, never the clubhouse, deck, or members.',
  },
  'venue': {
    eyebrow: 'Prepared for Hawaiʻi wedding, luau & event venues',
    h1: ['They\'re deciding by photo.', 'Let them decide by the real thing.'],
    lede: 'Every couple and every planner comparing venues is picturing the same evening: the light, the grounds, the water. A live view of your setting — on your own site — replaces a staged photo gallery with the actual place, right now, exactly as it looks tonight. It\'s the difference between "here\'s what it can look like" and "here\'s what it looks like."',
    points: [
      ['Decide by the real thing', 'Photos are curated; a live feed isn\'t. Couples and planners comparing venues see your grounds as they actually are, at the hour they\'re actually considering.'],
      ['Sell tomorrow tonight', 'A live sunset feed the evening before is the best advertisement your next event will ever get — the exact experience, streaming, before anyone commits.'],
      ['A portfolio that builds itself', 'Every month we cut branded clips from the feed — golden hour on the grounds, guests arriving — ready for your own marketing, no photographer on retainer.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your grounds stream exactly like this — co-branded, on your own site. The exact frame is approved by your team before anything is mounted.',
  },
  'rental': {
    eyebrow: 'Prepared for Hawaiʻi vacation rental & villa portfolios',
    h1: ['Every listing shows the same photos.', 'Yours can show the real thing, live.'],
    lede: 'A guest choosing between listings has only photos to go on — and every listing has good photos. A live view of the actual lanai, pool, or beach access says something a photo never can: this is real, and it looks like this right now. Add it once per property and every listing that carries it gets a quiet edge over the ones that don\'t.',
    points: [
      ['Proof, not just a photo', 'Anyone can stage a photo shoot. A live feed can only show what\'s actually there, at this hour, in this weather — which is exactly why it\'s convincing.'],
      ['It scales with the portfolio', 'The deal isn\'t one camera — it\'s a program. As many of your listings as you want carrying a live view, one relationship, one invoice, one point of contact for install and service across every property.'],
      ['Fewer "is this really it" messages', 'Guests who watch the feed before check-in arrive already sold. That\'s fewer anxious pre-arrival questions for your reservations team and fewer surprised guests at the door.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. One of your properties\' lanai, pool, or beach access streams exactly like this — co-branded, on that listing\'s own page.',
  },
  'fb': {
    eyebrow: 'Prepared for Hawaiʻi beachfront restaurants & bars',
    h1: ['Sunset over your lanai —', 'the table books itself.'],
    lede: 'People choose the restaurant with the view they can already see. A live feed of your oceanfront — the lanai at golden hour, the surf off the deck — on your own site turns a hungry browser into a reservation, and turns your sunset into content that keeps filling tables long after it sets.',
    points: [
      ['The view books the table', 'Diners deciding where to eat pick the place whose sunset they just watched. A live oceanfront feed on your site answers "where should we go" before they finish scrolling.'],
      ['Golden hour, on repeat', 'Every month we cut branded sunset and golden-hour clips from your feed — exactly the content your Instagram wants, ready to post, no photographer on the deck.'],
      ['Handled end to end', 'We mount it, aim it at the water, host it, watch it, and swap it if the salt wins. Your staff pours drinks, not cable.'],
    ],
    caption: 'Live right now from our camera at Lewers Street, Waikīkī. Your oceanfront, lanai, or deck streams exactly like this — co-branded, on your own site.',
  },
};

const c = CONTENT[archetype!];
const refSlug = `demo-${archetype}`;
const CLIP_BASE = 'https://ai.portofcams.com/static/clips';
const clips = [
  { src: `${CLIP_BASE}/demo-lewers-showcase.mp4`, label: 'Branded showcase clip — cut by the same pipeline that would serve your venue' },
  { src: `${CLIP_BASE}/gallery-lewers-golden-hour.mp4`, label: 'Golden hour, same view — a fresh mood we’d cut from your feed each month' },
];

const titles: Record<string, string> = {
  'hotel': 'Live Cam Demo for Hotels & Resorts — Port of Cams Pro',
  'marina': 'Live Cam Demo for Marinas & Harbors — Port of Cams Pro',
  'surf-shop': 'Live Cam Demo for Surf & Dive Shops — Port of Cams Pro',
  'dive': 'Live Cam Demo for Dive & Charter Operations — Port of Cams Pro',
  'club': 'Live Cam Demo for Ocean & Yacht Clubs — Port of Cams Pro',
  'venue': 'Live Cam Demo for Wedding, Luau & Event Venues — Port of Cams Pro',
  'rental': 'Live Cam Demo for Vacation Rental & Villa Portfolios — Port of Cams Pro',
  'fb': 'Live Cam Demo for Beachfront Restaurants & Bars — Port of Cams Pro',
};
---

<Layout title={titles[archetype!]} description="A live demonstration of the Managed Marketing Cam — what your venue's view looks like on your own website." noindex={true} includeHls={true} activeNav="">
  <main class="demo">

    <section class="d-hero">
      <div class="eyebrow mono">{c.eyebrow}</div>
      <h1>{c.h1[0]}<br /><em>{c.h1[1]}</em></h1>
      <p class="lede">{c.lede}</p>
    </section>

    <section class="d-live">
      <div class="d-live-tag mono">Live demonstration</div>
      <HLSPlayer hlsUrl="https://cams.portofcams.com/east-lewers-st/" cameraName="East Lewers Street, Waikīkī" poster="/clips/lewers-waikiki.jpg" />
      <p class="d-caption">{c.caption}</p>
    </section>

    <section class="d-points">
      {c.points.map(([h, b], i) => (
        <div class="d-point">
          <div class="d-n mono">{String(i + 1).padStart(2, '0')}</div>
          <h3>{h}</h3>
          <p>{b}</p>
        </div>
      ))}
    </section>

    <section class="d-clips">
      <div class="sec-head"><span class="mono tag">Included monthly</span><h2>Clips we cut from feeds like yours.</h2></div>
      <div class="d-clip-grid">
        {clips.map((clip) => (
          <figure class="d-clip">
            <video controls preload="metadata" playsinline src={clip.src}></video>
            <figcaption class="mono">{clip.label}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="d-terms">
      <div class="d-term"><span class="tv">$1,490+</span><span class="tl mono">professional install, billed at signup</span></div>
      <div class="d-term"><span class="tv">$149&ndash;199</span><span class="tl mono">per month, managed</span></div>
      <div class="d-term"><span class="tv">No lock-in</span><span class="tl mono">month-to-month, cancel with 30 days' notice</span></div>
    </section>

    <section class="d-cta">
      <a href={`/managed?ref=${refSlug}#pilot`} class="btn-gold">Get started</a>
      <a href="/managed" class="btn-ghost">Everything that&rsquo;s included</a>
      <div class="d-fine mono">pro.portofcams.com/managed &middot; portofcams@gmail.com &middot; Serving Oʻahu now</div>
    </section>

  </main>
</Layout>

<script>
  // Per-prospect attribution: /managed/demo/hotel?ref=twin-fin rewrites the
  // CTA's default archetype ref so the pilot form logs the prospect slug.
  const ref = (new URLSearchParams(window.location.search).get('ref') || '').slice(0, 64);
  if (ref) {
    document.querySelectorAll<HTMLAnchorElement>('a[href*="ref="]').forEach((a) => {
      const u = new URL(a.href);
      u.searchParams.set('ref', ref);
      a.href = u.toString();
    });
  }
</script>

<style>
  .demo { color: var(--white); overflow: hidden; padding-left: 24px; padding-right: 24px; }
  .demo h1, .demo h2, .demo h3 { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 600; }
  .demo .mono { font-family: 'DM Mono', monospace; }
  .demo p { font-family: 'DM Sans', system-ui, sans-serif; }
  .demo em { font-style: italic; color: var(--gold); }

  .d-hero { max-width: 860px; margin: 0 auto; padding-top: 132px; text-align: center; }
  .eyebrow { font-size: 12px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--gold); margin-bottom: 22px; }
  .d-hero h1 { font-size: clamp(34px, 6vw, 60px); line-height: 1.05; margin: 0; text-wrap: balance; }
  .lede { font-size: clamp(16px, 2.2vw, 18.5px); line-height: 1.65; color: rgba(245,240,232,0.72); max-width: 62ch; margin: 24px auto 0; }

  .d-live { max-width: 860px; margin: 0 auto; padding-top: 54px; }
  .d-live-tag { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; text-align: center; }
  .d-caption { font-size: 13.5px; line-height: 1.6; color: rgba(245,240,232,0.6); max-width: 68ch; margin: 14px auto 0; text-align: center; }

  .d-points { max-width: 1000px; margin: 0 auto; padding-top: 72px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .d-point { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 26px 24px; }
  .d-n { font-size: 12px; color: var(--gold); letter-spacing: 0.1em; margin-bottom: 12px; }
  .d-point h3 { font-size: 21px; margin: 0 0 8px; }
  .d-point p { font-size: 14px; line-height: 1.55; color: rgba(245,240,232,0.62); margin: 0; }

  .d-clips { padding-top: 84px; }
  .sec-head { max-width: 1000px; margin: 0 auto 30px; text-align: center; }
  .sec-head .tag { display: inline-block; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .sec-head h2 { font-size: clamp(26px, 4.5vw, 40px); margin: 0; }
  .d-clip-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; max-width: 900px; margin: 0 auto; }
  .d-clip { margin: 0; }
  .d-clip video { width: 100%; border-radius: 12px; border: 1px solid var(--border); background: #000; aspect-ratio: 16/9; }
  .d-clip figcaption { font-size: 11.5px; color: var(--muted); margin-top: 8px; line-height: 1.5; }

  .d-terms { display: flex; justify-content: center; gap: clamp(20px, 5vw, 60px); flex-wrap: wrap; max-width: 860px; margin: 0 auto; padding-top: 72px; }
  .d-term { display: flex; flex-direction: column; align-items: center; gap: 6px; max-width: 190px; text-align: center; }
  .tv { font-family: 'Cormorant Garamond', serif; font-size: 40px; color: var(--gold); line-height: 1; }
  .tl { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); }

  .d-cta { text-align: center; padding: 60px 0 100px; }
  .d-cta .btn-gold, .d-cta .btn-ghost { display: inline-block; margin: 0 6px; }
  .btn-gold { background: var(--gold); color: #1a1508; text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; padding: 14px 26px; border-radius: 8px; }
  .btn-ghost { border: 1px solid rgba(245,240,232,0.2); color: var(--white); text-decoration: none; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 15px; padding: 14px 26px; border-radius: 8px; }
  .btn-ghost:hover { border-color: var(--gold); }
  .d-fine { font-size: 12px; color: var(--muted); margin-top: 20px; }

  @media (max-width: 780px) {
    .d-points, .d-clip-grid { grid-template-columns: 1fr; }
    .d-hero { padding-top: 108px; }
  }

  /* Leave-behind: printing collapses players into the essentials */
  @media print {
    .d-live, .d-clips { display: none; }
    .demo { color: #000; }
    .d-cta .btn-gold, .d-cta .btn-ghost { border: 1px solid #000; color: #000; background: none; }
  }
</style>
