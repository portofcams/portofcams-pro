---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="PortOfCams Pro Blog — Live Streaming Guides for Venues & Destinations"
  description="Guides, case studies, and how-tos for venues, resorts, and destinations using live streaming and webcams to grow their audience."
  activeNav="">

  <style>
    .blog-index-hero {
      padding: 160px 48px 80px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .blog-index-hero .label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 20px;
    }
    .blog-index-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(40px, 6vw, 72px);
      font-weight: 600;
      line-height: 1.05;
      color: var(--white);
      margin-bottom: 20px;
    }
    .blog-index-hero p {
      color: var(--muted);
      font-size: 18px;
      max-width: 500px;
      line-height: 1.7;
    }
    .blog-grid-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 48px 120px;
    }
    .blog-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1px;
      border: 1px solid var(--border);
    }
    .blog-card {
      display: block;
      padding: 40px;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      text-decoration: none;
      transition: background 0.2s;
      color: inherit;
    }
    .blog-card:hover { background: var(--surface); }
    .card-label {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      display: block;
      margin-bottom: 12px;
    }
    .blog-card h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--white);
      line-height: 1.2;
      margin-bottom: 12px;
    }
    .blog-card p {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 20px;
    }
    .card-read {
      font-size: 13px;
      color: var(--gold);
      letter-spacing: 0.05em;
    }
    @media (max-width: 768px) {
      .blog-index-hero { padding: 120px 24px 60px; }
      .blog-grid-wrap { padding: 0 0 80px; }
      .blog-card { padding: 28px 24px; }
    }
  </style>

