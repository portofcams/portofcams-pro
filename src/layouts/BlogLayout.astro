---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  slug: string;
}

const { title, description, category, slug } = Astro.props;
---

<Layout title={`${title} | PortOfCams Pro`} description={description} activeNav="">
  <style>
    .blog-hero {
      padding: 160px 48px 80px;
      max-width: 900px;
      margin: 0 auto;
    }

    .blog-label {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .blog-label::after {
      content: '';
      width: 32px;
      height: 1px;
      background: var(--gold);
      opacity: 0.5;
    }

    .blog-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(36px, 5vw, 60px);
      font-weight: 600;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 20px;
    }

    .blog-meta {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--muted);
      letter-spacing: 0.1em;
    }

    .blog-divider {
      max-width: 900px;
      margin: 0 auto 0;
      border: none;
      border-top: 1px solid var(--border);
    }

    .blog-body {
      max-width: 720px;
      margin: 0 auto;
      padding: 64px 48px 100px;
      font-size: 17px;
      line-height: 1.8;
      color: rgba(245,240,232,0.75);
    }

    .blog-body :global(h2) {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 600;
      color: var(--white);
      margin: 52px 0 18px;
      letter-spacing: -0.01em;
      line-height: 1.2;
    }

    .blog-body :global(h3) {
      font-size: 17px;
      font-weight: 500;
      color: var(--white);
      margin: 32px 0 12px;
      letter-spacing: 0.02em;
    }

    .blog-body :global(p) {
      margin-bottom: 22px;
    }

    .blog-body :global(ul),
    .blog-body :global(ol) {
      margin: 0 0 22px 20px;
    }

    .blog-body :global(li) {
      margin-bottom: 10px;
    }

    .blog-body :global(strong) {
      color: var(--white);
      font-weight: 500;
    }

    .blog-body :global(.callout) {
      border-left: 2px solid var(--gold);
      padding: 20px 28px;
      margin: 36px 0;
      background: rgba(201,168,76,0.05);
    }

    .blog-body :global(.callout strong) {
      color: var(--gold);
    }

    .blog-cta {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 48px 100px;
    }

    .blog-cta-inner {
      border: 1px solid var(--border);
      background: var(--surface);
      padding: 48px;
      text-align: center;
    }

    .blog-cta-inner .eyebrow {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 16px;
    }

    .blog-cta-inner h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 36px;
      font-weight: 600;
      color: var(--white);
      margin-bottom: 14px;
      line-height: 1.15;
    }

    .blog-cta-inner p {
      color: var(--muted);
      margin-bottom: 32px;
      font-size: 15px;
      line-height: 1.7;
      max-width: 420px;
      margin-left: auto;
      margin-right: auto;
      margin-bottom: 32px;
    }

    @media (max-width: 768px) {
      .blog-hero { padding: 120px 24px 60px; }
      .blog-body { padding: 48px 24px 80px; }
      .blog-cta { padding: 0 24px 80px; }
      .blog-cta-inner { padding: 36px 24px; }
    }
  </style>

  <div class="blog-hero">
    <div class="blog-label">{category}</div>
    <h1>{title}</h1>
    <p class="blog-meta">PortOfCams Pro &nbsp;&middot;&nbsp; June 2026 &nbsp;&middot;&nbsp; 6 min read</p>
  </div>

  <hr class="blog-divider" />

  <div class="blog-body">
    <slot />
  </div>

  <div class="blog-cta">
    <div class="blog-cta-inner">
      <div class="eyebrow">Get Started</div>
      <h2>Put your venue <em style="font-style: italic; color: var(--gold)">on camera</em></h2>
      <p>Start free and set it up yourself, or have us handle the whole thing — pro install, monthly social clips, and salt-air service on the Managed plan for hotels, marinas, and resorts.</p>
      <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
        <a href="/host" class="btn-primary">Get a Free Camera</a>
        <a href="/managed" class="btn-secondary">Managed for your venue &rarr;</a>
      </div>
    </div>
  </div>
</Layout>
